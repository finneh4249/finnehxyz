---
interface Props {
  className?: string;
}

const { className = "" } = Astro.props;
---

<div class={`kernel-log-container signal-card border border-signal-white/10 shadow-signal-lg ${className}`}>
  <div class="signal-card-header bg-signal-black border-b border-signal-orange/30 px-4 py-3 flex justify-between items-center">
    <span class="flex items-center gap-3">
      <span class="w-2 h-2 rounded-full bg-signal-orange animate-pulse" id="status-indicator"></span>
      <span class="font-mono text-[11px] font-black tracking-[0.15em] text-signal-white/60 uppercase">GitHub Activity</span>
    </span>
    <button id="reconnect-btn" class="text-[9px] font-mono font-black text-signal-orange/60 hover:text-signal-orange transition-colors hidden uppercase tracking-widest">Retry</button>
  </div>
  <div class="font-mono text-[11px] leading-relaxed h-[320px] overflow-hidden relative bg-signal-black">
    <div class="absolute top-0 left-0 w-full h-[1px] bg-signal-orange/10 z-10 scan-line pointer-events-none"></div>

    <div id="log-stream" class="flex flex-col relative z-0 min-h-[200px] p-3 gap-0">
      <div class="text-signal-white/30 text-[10px] py-8 text-center">Loading...</div>
    </div>
  </div>
</div>

<script>
  import { formatLastSuccessLabel, getPushActionText } from "../../utils/githubActivity";

  const CACHE_KEY = 'gh_events_v1';
  const CACHE_TTL = 60 * 60 * 1000; // 1 hour
  const GITHUB_OWNER = 'finneh4249';
  const GITHUB_REPO = 'finnehxyz';
  const GITHUB_EVENTS_URL = `https://api.github.com/repos/${GITHUB_OWNER}/${GITHUB_REPO}/events?per_page=15`;

  function getCacheEntry(): { data: any[]; ts: number } | null {
    try {
      const raw = localStorage.getItem(CACHE_KEY);
      if (!raw) return null;
      const { data, ts } = JSON.parse(raw);
      if (!Array.isArray(data) || !Number.isFinite(ts)) return null;
      return { data, ts };
    } catch { return null; }
  }

  function getCached(): any[] | null {
    try {
      const cached = getCacheEntry();
      if (!cached) return null;
      const { data, ts } = cached;
      if (Date.now() - ts > CACHE_TTL) { localStorage.removeItem(CACHE_KEY); return null; }
      return data;
    } catch { return null; }
  }

  function setCached(data: any[]) {
    try { localStorage.setItem(CACHE_KEY, JSON.stringify({ data, ts: Date.now() })); } catch {}
  }

  async function fetchGithubEvents(force = false) {
    const stream = document.getElementById('log-stream');
    const indicator = document.getElementById('status-indicator');
    const reconnectBtn = document.getElementById('reconnect-btn');
    if (!stream || !indicator || !reconnectBtn) return;

    // Serve from cache if fresh
    if (!force) {
      const cached = getCached();
      if (cached) {
        renderEvents(cached, stream, indicator, reconnectBtn);
        return;
      }
    }

    indicator.classList.remove('bg-signal-green', 'bg-signal-orange', 'bg-signal-amber', 'animate-ping');
    indicator.classList.add('bg-signal-amber', 'animate-ping');

    try {
      const response = await fetch(GITHUB_EVENTS_URL, {
        cache: 'no-store',
        headers: {
          Accept: 'application/vnd.github+json',
        },
      });
      if (!response.ok) {
        if (response.status === 403) throw new Error('RATE_LIMIT');
        throw new Error('OFFLINE');
      }
      const events = await response.json();
      if (!Array.isArray(events)) {
        throw new Error('INVALID_RESPONSE');
      }
      setCached(events);
      renderEvents(events, stream, indicator, reconnectBtn);
    } catch (err: any) {
      indicator.classList.remove('animate-ping', 'bg-signal-amber');
      indicator.classList.add('bg-signal-orange');
      reconnectBtn.classList.remove('hidden');
      const msg =
        err.message === 'RATE_LIMIT'
          ? 'Rate limited — showing cached data when available.'
          : err.message === 'INVALID_RESPONSE'
            ? 'Received unexpected data format from GitHub.'
            : 'Could not fetch activity.';
      const lastSuccess = formatLastSuccessLabel(getCacheEntry()?.ts);
      // Try to fall back to stale cache
      const stale = getCacheEntry()?.data;
      if (stale) {
        renderEvents(stale, stream, indicator, reconnectBtn);
        stream.insertAdjacentHTML('afterbegin', `<div class="text-signal-orange/50 text-[9px] font-mono px-1 py-1 mb-1">${msg}</div>`);
        if (lastSuccess) {
          stream.insertAdjacentHTML('afterbegin', `<div class="text-signal-white/30 text-[9px] font-mono px-1 pt-1">${lastSuccess}</div>`);
        }
      } else {
        stream.innerHTML = `<div class="text-signal-white/30 text-center py-12 text-[11px]">${msg}${lastSuccess ? `<br/><span class="text-[10px]">${lastSuccess}</span>` : ''}</div>`;
      }
    }
  }

  function renderEvents(events: any[], stream: HTMLElement, indicator: HTMLElement, reconnectBtn: HTMLElement) {
    stream.innerHTML = '';
    reconnectBtn.classList.add('hidden');
    indicator.classList.remove('animate-ping', 'bg-signal-amber', 'bg-signal-orange');
    indicator.classList.add('bg-signal-green');

    if (!events || events.length === 0) {
      stream.innerHTML = '<div class="text-signal-white/30 text-center py-8 text-[10px]">No recent activity found.</div>';
      return;
    }

    events.forEach((event: any, i: number) => {
      const date = new Date(event.created_at).toLocaleString([], { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit', hour12: false });
      const repo = event.repo.name.split('/')[1] || event.repo.name;
      let action = '';
      let colorClass = 'text-signal-white/50';
      if (event.type === 'PushEvent') {
        action = getPushActionText(event.payload);
        colorClass = 'text-signal-cyan';
      } else if (event.type === 'PullRequestEvent') {
        action = `${event.payload.action} PR in`;
        colorClass = 'text-signal-amber';
      } else if (event.type === 'CreateEvent') {
        action = `created ${event.payload.ref_type || 'repo'} in`;
        colorClass = 'text-signal-white/60';
      } else if (event.type === 'WatchEvent') {
        action = 'starred'; colorClass = 'text-signal-white/40';
      } else {
        action = event.type.replace('Event', '').toLowerCase() + ' in';
      }
      const line = document.createElement('div');
      line.className = 'log-line border-b border-white/5 py-2 px-1 flex justify-between gap-3 items-baseline';
      line.style.opacity = '0';
      line.style.animation = `logReveal 0.3s ease forwards ${i * 40}ms`;
      line.innerHTML = `
        <div class="flex gap-2 overflow-hidden min-w-0">
          <span class="${colorClass} shrink-0">&rsaquo;</span>
          <span class="text-signal-white/70 truncate">${action} <span class="text-signal-white font-bold">${repo}</span></span>
        </div>
        <span class="text-signal-white/25 shrink-0 text-[9px] whitespace-nowrap">${date}</span>
      `;
      stream.appendChild(line);
    });
  }

  // Initial load
  fetchGithubEvents();

  // Retry button clears cache and forces fresh fetch
  document.getElementById('reconnect-btn')?.addEventListener('click', () => {
    localStorage.removeItem(CACHE_KEY);
    fetchGithubEvents(true);
  });
  // No auto-refresh loop — cache handles staleness

</script>


<style>
  .kernel-log-container {
    height: 100%;
  }

  .log-line {
    opacity: 0;
  }

  .scan-line {
    animation: scan 4s linear infinite;
  }

  @keyframes scan {
    from { transform: translateY(-100%); }
    to { transform: translateY(320px); }
  }

  @keyframes logReveal {
    from { opacity: 0; transform: translateX(-6px); }
    to { opacity: 1; transform: translateX(0); }
  }

  .animate-reveal {
    animation: reveal 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes reveal {
    from { opacity: 0; transform: translateX(-10px); filter: blur(2px); }
    to { opacity: 1; transform: translateX(0); filter: blur(0); }
  }
</style>
