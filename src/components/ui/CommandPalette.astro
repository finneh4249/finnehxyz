---
---

<div id="cmd-palette" class="cmd-palette" style="display: none;">
  <div class="cmd-palette-box border-2 border-signal-orange">
    <div class="p-4 border-b border-signal-white/10 bg-signal-charcoal">
      <div class="flex items-center gap-3">
        <span class="text-signal-orange font-mono text-lg font-black">&gt;</span>
        <input 
          id="cmd-input"
          type="text"
          class="bg-transparent border-none outline-none font-mono text-sm text-signal-white w-full placeholder-signal-white/30"
          placeholder="System_Navigate: Type_Query..."
          autocomplete="off"
        />
        <kbd class="text-[10px] font-mono text-signal-white/40 border border-signal-white/20 px-2 py-1" id="cmd-esc">ESC</kbd>
      </div>
    </div>
    <div id="cmd-results" class="max-h-64 overflow-y-auto bg-signal-black"></div>
    <div class="p-2 border-t border-signal-white/5 bg-signal-charcoal/50 flex justify-between items-center px-4">
      <span class="font-mono text-[9px] text-signal-white/20 uppercase tracking-widest">Operator_Link_Secure</span>
      <span class="font-mono text-[9px] text-signal-orange/40 uppercase">v5.0_CMD</span>
    </div>
  </div>
</div>

<script>
  (function() {
    if (window.__cmdPaletteInit) return;
    window.__cmdPaletteInit = true;
    
    const commands = [
      { label: 'Terminal_Home', desc: 'Return to start', target: 'top' },
      { label: 'Cargo_Manifest', desc: 'Featured projects', target: 'projects' },
      { label: 'System_Logs', desc: 'Recent blog posts', target: '/blog' },
      { label: 'Operational_History', desc: 'Experience timeline', target: 'history' },
      { label: 'Personnel_File', desc: 'Full resume', target: '/resume' },
      { label: 'Comms_Link', desc: 'Contact operator', target: 'contact' },
    ];
    
    let activeIndex = 0;
    let filtered = [...commands];
    
    function getPalette() { return document.getElementById('cmd-palette'); }
    function getInput() { return document.getElementById('cmd-input') as HTMLInputElement | null; }
    function getResults() { return document.getElementById('cmd-results'); }
    
    function isOpen() {
      const p = getPalette();
      return p ? p.style.display === 'flex' : false;
    }
    
    function render() {
      const r = getResults();
      if (!r) return;
      r.innerHTML = '';
      filtered.forEach((cmd, i) => {
        const item = document.createElement('div');
        item.className = `cmd-palette-item px-4 py-3 font-mono text-sm cursor-pointer transition-all border-b border-signal-white/5 ${i === activeIndex ? 'bg-signal-orange text-signal-black' : 'text-signal-white/60 hover:bg-signal-white/5'}`;
        item.innerHTML = `
          <div class="flex justify-between items-center">
            <span class="font-bold">${cmd.label.toUpperCase()}</span>
            <span class="text-[10px] opacity-60">${cmd.desc}</span>
          </div>
        `;
        item.addEventListener('click', () => navigate(cmd.target));
        r.appendChild(item);
      });
    }
    
    function navigate(target: string) {
      if (target.startsWith('/')) {
        window.location.href = target;
        return;
      }
      
      const el = target === 'top' ? document.body : document.getElementById(target) || document.querySelector(`[id="${target}"]`);
      if (el) {
        el.scrollIntoView({ behavior: 'smooth', block: 'start' });
      } else {
         // Fallback to sections
         const section = document.querySelector(`section:has(h2:contains("${target.toUpperCase()}"))`);
         section?.scrollIntoView({ behavior: 'smooth' });
      }
      closePalette();
    }
    
    function openPalette() {
      const p = getPalette();
      const i = getInput();
      if (!p) return;
      p.style.display = 'flex';
      if (i) { i.value = ''; }
      activeIndex = 0;
      filtered = [...commands];
      render();
      setTimeout(() => i?.focus(), 50);
    }
    
    function closePalette() {
      const p = getPalette();
      const i = getInput();
      if (!p) return;
      p.style.display = 'none';
      i?.blur();
    }
    
    // Global keyboard handler
    document.addEventListener('keydown', (e) => {
      if (e.key === '/' && !isOpen()) {
        const tag = (e.target as HTMLElement)?.tagName;
        if (tag !== 'INPUT' && tag !== 'TEXTAREA') {
          e.preventDefault();
          openPalette();
        }
      } else if (e.key === 'Escape' && isOpen()) {
        e.preventDefault();
        e.stopPropagation();
        closePalette();
      }
    });
    
    // Input navigation
    document.addEventListener('keydown', (e) => {
      if (!isOpen()) return;
      const i = getInput();
      if (document.activeElement !== i) return;
      
      if (e.key === 'ArrowDown') { e.preventDefault(); activeIndex = Math.min(activeIndex + 1, filtered.length - 1); render(); }
      if (e.key === 'ArrowUp') { e.preventDefault(); activeIndex = Math.max(activeIndex - 1, 0); render(); }
      if (e.key === 'Enter' && filtered[activeIndex]) { navigate(filtered[activeIndex].target); }
    });
    
    // Search filter
    document.addEventListener('input', (e) => {
      if ((e.target as HTMLElement)?.id !== 'cmd-input') return;
      const q = (e.target as HTMLInputElement).value.toLowerCase();
      filtered = commands.filter(c => c.label.toLowerCase().includes(q) || c.desc.toLowerCase().includes(q));
      activeIndex = 0;
      render();
    });
    
    // Backdrop click to close
    document.addEventListener('click', (e) => {
      const p = getPalette();
      if (isOpen() && e.target === p) closePalette();
    });
    
    // ESC button click
    document.getElementById('cmd-esc')?.addEventListener('click', closePalette);
    
    // Expose for trigger button
    (window as any).__openCmdPalette = openPalette;
  })();
</script>

<style>
  .cmd-palette {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(4px);
    display: none;
    justify-content: center;
    align-items: flex-start;
    padding-top: 15vh;
  }

  .cmd-palette-box {
    width: 100%;
    max-width: 600px;
    box-shadow: 20px 20px 0px 0px rgba(0, 0, 0, 0.5);
  }
</style>
