---
import CompanyRole from './CompanyRole.astro';
import { Image } from 'astro:assets';

interface Role {
  title: string;
  period: string;
  isCurrent?: boolean;
  description?: string;
}

interface Props {
  yearRange: string;
  company: string;
  employer?: string;
  roles: Role[];
  logoSrc?: ImageMetadata;
  logoSrcs?: ImageMetadata[];
  logoAlt: string;
  index: number;
  isFirst?: boolean;
  isLast?: boolean;
  category?: string;
}

const { 
  yearRange, 
  company, 
  employer, 
  roles, 
  logoSrc, 
  logoSrcs, 
  logoAlt, 
  index,
  category = 'technology',
} = Astro.props;

const accentColor = category === 'technology' ? 'cyber-cyan' : 'cyber-magenta';
const accentBorder = category === 'technology' ? 'border-cyber-cyan/30' : 'border-cyber-magenta/30';
const accentGlow = category === 'technology' 
  ? '0 0 10px rgba(0, 255, 245, 0.1)' 
  : '0 0 10px rgba(255, 0, 255, 0.1)';
---

<div class="relative w-full animate-on-scroll slide-up">
  <div class="cyber-card border-2 border-cyber-border hover:border-cyber-cyan/50 transition-all duration-300 overflow-hidden"
       style={`box-shadow: 4px 4px 0px 0px #2a2a3a; border-left: 3px solid var(--accent-color);`}>
    
    <div class="p-6">
      <!-- Header -->
      <div class="flex items-start gap-4 mb-4">
        <!-- Logo -->
        {(logoSrcs && logoSrcs.length > 0) ? (
          <div class="flex gap-2">
            {logoSrcs.map((src, idx) => (
              <div class="w-12 h-12 bg-white border border-cyber-border p-1.5 flex items-center justify-center flex-shrink-0">
                <Image src={src} alt={`${logoAlt} ${idx + 1}`} class="w-full h-full object-contain" />
              </div>
            ))}
          </div>
        ) : (
          logoSrc && (
            <div class="w-12 h-12 bg-white border border-cyber-border p-1.5 flex items-center justify-center flex-shrink-0">
              <Image src={logoSrc} alt={logoAlt} class="w-full h-full object-contain" />
            </div>
          )
        )}
        
        <div class="flex-1 min-w-0">
          <h3 class="text-xl font-black uppercase leading-tight text-white truncate">{company}</h3>
          {employer && <div class="text-sm font-mono text-cyber-text-muted">{employer}</div>}
          <span class="font-mono text-xs text-cyber-text-muted mt-1 inline-block">// {yearRange}</span>
        </div>
      </div>

      <!-- Roles -->
      <div class="space-y-4">
        {roles.map((role, idx) => (
          <CompanyRole 
            title={role.title} 
            period={role.period} 
            isCurrent={role.isCurrent} 
            description={role.description} 
            isLast={idx === roles.length - 1} 
          />
        ))}
      </div>
    </div>
  </div>
</div>

<style define:vars={{ 'accent-color': `var(--tw-cyber-${accentColor === 'cyber-cyan' ? 'cyan' : 'magenta'}, ${accentColor === 'cyber-cyan' ? '#00fff5' : '#ff00ff'})` }}>
</style>