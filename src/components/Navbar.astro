---
import ScrollProgressBar from './ScrollProgressBar.astro';
import { Icon } from 'astro-icon/components';

const navLinks = [
  { id: 'hero', label: 'Home', type: 'anchor' },
  { id: 'projects', label: 'Projects', type: 'anchor' },
  { id: 'aboutme', label: 'About', type: 'anchor' },
  { id: 'professionalExperience', label: 'Experience', type: 'anchor' },
  { id: 'skills', label: 'Skills', type: 'anchor' },
  { href: '/blog', label: 'Blog', type: 'page' },
  { id: 'contact', label: 'Contact', type: 'anchor' }
];

interface Props {
  activeSection?: string;
}

const { activeSection } = Astro.props;
---

<nav
  id="main-nav"
  class="fixed bottom-8 left-1/2 -translate-x-1/2 z-50 transition-all duration-300"
>
  <ScrollProgressBar className="fixed top-0 left-0 w-full z-[60]" />
  
  <!-- Floating Cyber Dock -->
  <div class="bg-cyber-surface/95 backdrop-blur-md border-2 border-cyber-border p-2 flex items-center gap-2 md:gap-3 transform hover:-translate-y-1 transition-transform duration-200"
       style="box-shadow: 0 0 20px rgba(0, 255, 245, 0.1), 4px 4px 0px 0px #2a2a3a;">
    
    <!-- Logo / Home -->
    <a 
      href="#hero" 
      id="nav-logo"
      class="cyber-btn bg-cyber-cyan text-cyber-bg w-11 h-11 flex items-center justify-center border-2 border-cyber-cyan !shadow-none hover:!bg-cyber-magenta hover:!border-cyber-magenta hover:!text-white transition-colors px-0 py-0"
      title="Home"
    >
      <span class="font-black text-lg font-mono">EC</span>
    </a>

    <!-- Desktop Links -->
    <div class="hidden md:flex items-center gap-1">
      {navLinks.map(link => (
        <a
          href={link.type === 'page' ? link.href : `#${link.id}`}
          class:list={[
            "px-3 py-2 font-mono font-bold uppercase text-xs border border-transparent hover:border-cyber-cyan hover:text-cyber-cyan transition-all tracking-wider",
            activeSection === link.id ? 'bg-cyber-cyan/10 text-cyber-cyan border-cyber-cyan' : 'text-cyber-text-muted'
          ]}
          data-id={link.id}
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Mobile Menu Toggle -->
    <button 
      id="mobile-menu-toggle"
      class="md:hidden cyber-btn w-11 h-11 p-0 flex items-center justify-center border-2 !shadow-none relative overflow-hidden"
      aria-label="Toggle menu"
    >
      <Icon name="mdi:menu" class="w-7 h-7 text-cyber-text absolute transition-all duration-300 menu-icon-open" style="color: inherit;" />
      <Icon name="mdi:close" class="w-7 h-7 text-cyber-text absolute transition-all duration-300 menu-icon-close opacity-0 rotate-90 scale-50" style="color: inherit;" />
    </button>
  </div>

  <!-- Mobile Menu -->
  <div 
    id="mobile-menu"
    class="absolute bottom-full left-0 w-full mb-4 bg-cyber-surface/95 backdrop-blur-md border-2 border-cyber-border p-4 transform scale-y-0 origin-bottom transition-transform duration-200 md:hidden"
    style="box-shadow: 0 0 20px rgba(0, 255, 245, 0.1), 4px 4px 0px 0px #2a2a3a;"
  >
    <ul class="space-y-1">
      {navLinks.map(link => (
        <li>
          <a 
            href={link.type === 'page' ? link.href : `#${link.id}`}
            class:list={[
              "block w-full text-center py-3 font-mono font-bold uppercase text-sm border border-transparent hover:border-cyber-cyan hover:text-cyber-cyan transition-all tracking-wider",
              activeSection === link.id ? 'bg-cyber-cyan/10 text-cyber-cyan border-cyber-cyan' : 'text-cyber-text-muted'
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  function initNavbar() {
    const nav = document.getElementById('main-nav');
    const toggleBtn = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    
    if (!nav || !toggleBtn || !menu) return;

    const menuIconOpen = toggleBtn.querySelector('.menu-icon-open');
    const menuIconClose = toggleBtn.querySelector('.menu-icon-close');

    let isMenuOpen = false;

    const toggleMenu = () => {
      isMenuOpen = !isMenuOpen;
      if (isMenuOpen) {
        menu.classList.remove('scale-y-0');
        if (menuIconOpen && menuIconClose) {
          menuIconOpen.classList.add('opacity-0', 'rotate-90', 'scale-50');
          menuIconClose.classList.remove('opacity-0', 'rotate-90', 'scale-50');
        }
      } else {
        menu.classList.add('scale-y-0');
        if (menuIconOpen && menuIconClose) {
          menuIconOpen.classList.remove('opacity-0', 'rotate-90', 'scale-50');
          menuIconClose.classList.add('opacity-0', 'rotate-90', 'scale-50');
        }
      }
    };

    toggleBtn.addEventListener('click', toggleMenu);

    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        if (isMenuOpen) toggleMenu();
      });
    });

    // Active Section Highlighting
    const observerOptions = {
      root: null,
      rootMargin: '-20% 0px -70% 0px',
      threshold: 0
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          updateActiveLink(id);
        }
      });
    }, observerOptions);

    document.querySelectorAll('section[id]').forEach(section => {
      observer.observe(section);
    });

    function updateActiveLink(id: string) {
      document.querySelectorAll('[data-id]').forEach(link => {
        const href = link.getAttribute('href');
        if (href === `#${id}`) {
          link.classList.add('bg-cyber-cyan/10', 'text-cyber-cyan', 'border-cyber-cyan');
          link.classList.remove('text-cyber-text-muted');
        } else {
          link.classList.remove('bg-cyber-cyan/10', 'text-cyber-cyan', 'border-cyber-cyan');
          link.classList.add('text-cyber-text-muted');
        }
      });
    }
  }

  initNavbar();
  document.addEventListener('astro:page-load', initNavbar);
</script>