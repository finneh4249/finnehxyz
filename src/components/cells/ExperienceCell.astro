---
import experienceData from '../../data/experience.json';
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface Role {
  title: string;
  period: string;
  isCurrent?: boolean;
  description?: string;
}

interface Experience {
  yearRange: string;
  company: string;
  employer?: string;
  category: 'technology' | 'operations';
  roles: Role[];
  logoSrc?: string;
  logoAlt?: string;
}

interface Props {
  category: 'technology' | 'operations';
}

const { category } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/*.{jpeg,jpg,png,gif,webp}', { eager: true });
const getImagePath = (path: string) => {
  if (!path) return undefined;
  const normalizedPath = path.replace(/^(\.\/)?images\//, '/src/assets/images/');
  return images[normalizedPath]?.default;
};

const experiences = (experienceData as Experience[]).filter(e => e.category === category);
const isTech = category === 'technology';
const cellClass = isTech ? 'cell-exp-tech' : 'cell-exp-ops';
const revealDir = isTech ? 'reveal-left' : 'reveal-right';

// Full static class names so Tailwind's scanner can detect them
const classes = isTech
  ? {
      dot: 'bg-cyber-cyan',
      borderLeft: 'border-l-cyber-cyan',
      border: 'border-cyber-cyan',
      text: 'text-cyber-cyan',
      bg5: 'bg-cyber-cyan/5',
    }
  : {
      dot: 'bg-cyber-magenta',
      borderLeft: 'border-l-cyber-magenta',
      border: 'border-cyber-magenta',
      text: 'text-cyber-magenta',
      bg5: 'bg-cyber-magenta/5',
    };
---

<div class={`bento-cell ${cellClass} reveal ${revealDir} stagger-3`}>
  <div class="bento-cell-header flex items-center gap-2">
    <span class={`w-2 h-2 ${classes.dot}`}></span>
    <span>// {category}</span>
  </div>
  <div class="bento-cell-content space-y-4">
    {experiences.map((exp) => {
      const logo = getImagePath(exp.logoSrc ?? '');
      return (
        <div class={`bg-cyber-bg border border-cyber-border p-4 border-l-2 ${classes.borderLeft} hover:border-l-4 transition-all`}>
          <div class="flex items-start gap-3">
            {logo && (
              <div class="w-10 h-10 bg-white border border-cyber-border p-1 flex items-center justify-center flex-shrink-0">
                <Image src={logo} alt={exp.logoAlt ?? ''} class="w-full h-full object-contain" width={40} height={40} />
              </div>
            )}
            <div class="flex-1 min-w-0">
              <h3 class="text-sm font-bold uppercase text-white leading-tight">{exp.company}</h3>
              {exp.employer && <p class="text-xs font-mono text-cyber-text-muted mt-0.5">{exp.employer}</p>}
              <p class="text-xs font-mono text-cyber-text-muted mt-0.5">// {exp.yearRange}</p>
            </div>
          </div>

          <div class="mt-3 space-y-3">
            {exp.roles.map((role) => (
              <div class="border-t border-cyber-border/50 pt-3">
                <div class="flex items-center justify-between gap-2 flex-wrap">
                  <span class="text-xs font-bold text-white uppercase">{role.title}</span>
                  <div class="flex items-center gap-2">
                    {role.isCurrent && (
                      <span class={`text-[8px] font-mono font-bold uppercase border ${classes.border} ${classes.text} px-1.5 py-0.5 tracking-wider ${classes.bg5}`}>
                        Active
                      </span>
                    )}
                    <span class="text-[10px] font-mono text-cyber-text-muted">{role.period}</span>
                  </div>
                </div>
                {role.description && (
                  <div class="mt-2 text-xs text-cyber-text leading-relaxed space-y-1">
                    {role.description.split('\n').map((line: string) => (
                      line.startsWith('- ') ? (
                        <div class="flex items-start gap-1.5">
                          <span class={`w-1 h-1 ${classes.dot} mt-1.5 flex-shrink-0`}></span>
                          <span>{line.substring(2)}</span>
                        </div>
                      ) : (
                        <p>{line}</p>
                      )
                    ))}
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      );
    })}
  </div>
</div>
