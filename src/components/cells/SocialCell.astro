---
import { Icon } from 'astro-icon/components';
---

<div class="bento-cell cell-social reveal reveal-right stagger-4">
  <div class="bento-cell-header">// connect</div>
  <div class="bento-cell-content">
    <div class="grid grid-cols-4 gap-2">
      <a href="https://github.com/finneh4249" target="_blank" rel="noopener noreferrer" aria-label="GitHub profile"
        class="flex items-center justify-center aspect-square border border-cyber-border hover:border-white hover:text-white text-cyber-text-muted transition-all hover:shadow-glow-cyan">
        <Icon name="mdi:github" class="text-xl md:text-2xl" aria-hidden="true" />
      </a>
      <a href="https://www.linkedin.com/in/ethan-cornwill/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn profile"
        class="flex items-center justify-center aspect-square border border-cyber-border hover:border-cyber-blue hover:text-cyber-blue text-cyber-text-muted transition-all">
        <Icon name="mdi:linkedin" class="text-xl md:text-2xl" aria-hidden="true" />
      </a>
      <a href="https://x.com/FinnehReform" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter) profile"
        class="flex items-center justify-center aspect-square border border-cyber-border hover:border-cyber-cyan hover:text-cyber-cyan text-cyber-text-muted transition-all">
        <Icon name="mdi:twitter" class="text-xl md:text-2xl" aria-hidden="true" />
      </a>
      <a href="https://cityloopers.com/discord" target="_blank" rel="noopener noreferrer" aria-label="Discord server"
        class="flex items-center justify-center aspect-square border border-cyber-border hover:border-cyber-purple hover:text-cyber-purple text-cyber-text-muted transition-all">
        <Icon name="mdi:discord" class="text-xl md:text-2xl" aria-hidden="true" />
      </a>
    </div>
  </div>
</div>
