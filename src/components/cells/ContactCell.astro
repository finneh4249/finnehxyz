<div class="bento-cell cell-contact reveal reveal-up stagger-2">
  <div class="bento-cell-header">// contact</div>
  <div class="bento-cell-content">
    <div class="flex flex-col md:flex-row gap-4 items-stretch">
      <!-- Terminal-style message area -->
      <div class="flex-1 space-y-3">
        <div class="font-mono text-sm text-cyber-text">
          <span class="text-cyber-text-muted">guest@finneh.xyz:~$</span> cat contact.txt
        </div>
        <div class="bg-cyber-bg border border-cyber-border p-4 space-y-2">
          <p class="text-sm text-cyber-text leading-relaxed">
            Got a project idea, job opportunity, or just want to chat about AI systems? 
            I'm always interested in interesting problems.
          </p>
          <div class="flex items-center gap-2 pt-2 border-t border-cyber-border/50">
            <span class="font-mono text-xs text-cyber-text-muted">&gt;</span>
            <a href="mailto:mail@finneh.xyz" class="font-mono text-sm text-cyber-cyan hover:underline transition-all">
              mail@finneh.xyz
            </a>
          </div>
        </div>
      </div>
      
      <!-- Quick action buttons -->
      <div class="flex md:flex-col gap-2 md:justify-center">
        <a href="mailto:mail@finneh.xyz" class="cyber-btn-primary px-5 py-3 text-xs text-center whitespace-nowrap">
          SEND_MSG()
        </a>
        <a href="https://www.linkedin.com/in/ethan-cornwill/" target="_blank" rel="noopener noreferrer" class="cyber-btn px-5 py-3 text-xs text-center whitespace-nowrap hover:border-cyber-blue hover:text-cyber-blue">
          LINKEDIN
        </a>
        <a href="https://github.com/finneh4249" target="_blank" rel="noopener noreferrer" class="cyber-btn px-5 py-3 text-xs text-center whitespace-nowrap hover:border-white hover:text-white">
          GITHUB
        </a>
      </div>
    </div>
    
    <p class="text-[10px] font-mono text-cyber-text-muted mt-3">
      // Response time: usually within 24 hours. Carrier pigeons not currently supported.
    </p>
  </div>
</div>
