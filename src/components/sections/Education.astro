---
import EducationItem from '../education/EducationItem.astro';
import educationItems from '../../data/education.json';
import type { ImageMetadata } from 'astro';

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/*.{jpeg,jpg,png,gif,webp}', { eager: true });

const getImagePath = (path: string) => {
  if (!path) return undefined;
  const normalizedPath = path.replace(/^(\.\/)?images\//, '/src/assets/images/');
  return images[normalizedPath]?.default;
};
---

<section id="education" class="py-20 bg-cyber-surface relative overflow-hidden">
  <!-- Background accents -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-cyber-green/3 blur-3xl pointer-events-none"></div>
  
  <div class="container mx-auto px-4 relative z-10">
    <!-- Section header -->
    <div class="mb-12 animate-on-scroll slide-left">
      <div class="flex items-center gap-4 flex-wrap mb-4">
        <h2 class="text-5xl md:text-7xl font-black uppercase tracking-tighter text-white">
          Education
        </h2>
        <span class="category-badge-tech">// LEARNING</span>
      </div>
      <div class="h-0.5 w-48 bg-gradient-to-r from-cyber-green to-transparent"></div>
    </div>

    <!-- Compact vertical list -->
    <div class="max-w-4xl mx-auto space-y-4">
      {educationItems.map((item, index) => (
        <div class="cyber-card border border-cyber-border hover:border-cyber-green/50 transition-all duration-300 p-5"
             style="box-shadow: 3px 3px 0px 0px #2a2a3a; border-left: 3px solid #39ff14;">
          <div class="flex items-start gap-4">
            {getImagePath(item.logoSrc) && (
              <div class="w-10 h-10 bg-white border border-cyber-border p-1 flex items-center justify-center flex-shrink-0">
                <img src={getImagePath(item.logoSrc)?.src} alt={item.logoAlt} class="w-full h-full object-contain" />
              </div>
            )}
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-3 flex-wrap">
                <h3 class="font-bold uppercase text-white text-base">{item.institution}</h3>
                <span class="font-mono text-xs text-cyber-text-muted">// {item.year}</span>
              </div>
              <p class="text-sm text-cyber-cyan font-mono mt-1">{item.program}</p>
              {item.description && (
                <p class="text-sm text-cyber-text-muted mt-2">{item.description}</p>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>