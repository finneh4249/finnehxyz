---
import ToolCard from '../skills/ToolCard.astro';
import SkillCard from '../skills/SkillCard.astro';
import SearchFilter from '../ui/SearchFilter.astro';
import skillsData from '../../data/skills.json';

const toolCategories = ["All", ...new Set(skillsData.tools.map(tool => tool.category))];
const skillCategories = ["All", ...new Set(skillsData.skills.map(skill => skill.category))];
---

<section id="skills" class="py-20 bg-cyber-bg relative overflow-hidden">
  <!-- Background accents -->
  <div class="absolute top-1/3 -right-48 w-96 h-96 bg-cyber-magenta/3 blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-1/3 -left-48 w-96 h-96 bg-cyber-green/3 blur-3xl pointer-events-none"></div>
  
  <div class="container mx-auto px-4 md:px-6 relative z-10">
    <!-- Languages & Tools -->
    <div class="mb-20">
      <div class="mb-12 animate-on-scroll slide-up">
        <div class="flex items-center gap-4 flex-wrap mb-4">
          <span class="category-badge-tech">// TOOLS</span>
          <h1 class="text-5xl md:text-7xl font-black uppercase tracking-tighter neon-cyan">
            Languages & Tools
          </h1>
        </div>
        <div class="h-0.5 w-48 bg-gradient-to-r from-cyber-cyan to-transparent"></div>
      </div>
      
      <p class="text-cyber-text-muted font-mono text-sm mb-8">// Hover to see proficiency levels</p>
      
      <!-- Category Filters -->
      <div class="flex flex-wrap gap-2 mb-8" id="tool-categories">
        {toolCategories.map((category) => (
          <button
            class:list={[
              "cyber-btn px-4 py-2 text-xs font-mono category-btn transition-all",
              category === "All" ? "border-cyber-cyan text-cyber-cyan bg-cyber-cyan/10" : "border-cyber-border text-cyber-text-muted"
            ]}
            data-category={category}
          >
            {category}
          </button>
        ))}
      </div>
      
      <div id="tools-grid" class="flex flex-wrap gap-3">
        {skillsData.tools.map((tool, index) => (
          <div 
            class="tool-item transform transition-all duration-300 hover:scale-105 hover:z-10"
            data-name={tool.name.toLowerCase()}
            data-category={tool.category}
            data-proficiency={tool.proficiency}
          >
            <div class="bg-cyber-surface border border-cyber-border p-3 flex flex-col gap-2 min-w-[140px] group hover:border-cyber-cyan transition-all"
                 style="box-shadow: 3px 3px 0px 0px #2a2a3a;">
              <div class="flex items-center gap-2">
                <i class={`bx ${tool.icon} text-xl ${tool.color}`}></i>
                <div>
                  <span class="font-bold uppercase text-xs block leading-none text-white">{tool.name}</span>
                  <span class="text-[10px] text-cyber-text-muted font-mono">{tool.category}</span>
                </div>
              </div>
              <!-- Proficiency Bar -->
              <div class="w-full h-1 bg-cyber-border overflow-hidden">
                <div 
                  class="h-full bg-cyber-cyan transition-all duration-500 group-hover:bg-cyber-magenta"
                  style={`width: ${tool.proficiency}%`}
                ></div>
              </div>
              <div class="text-[10px] font-mono text-right text-cyber-text-muted">{tool.proficiency}%</div>
            </div>
          </div>
        ))}
      </div>
      
      <div id="no-tools-found" class="text-center py-8 cyber-card p-6 hidden">
        <p class="text-lg font-bold uppercase font-mono text-cyber-text-muted">// No matching tools found.</p>
        <button id="reset-tools" class="cyber-btn-primary px-6 py-3 mt-4 text-sm">
          Reset Filters
        </button>
      </div>
    </div>

    <!-- Skills Section -->
    <div>
      <div class="mb-12 animate-on-scroll slide-up">
        <div class="flex items-center gap-4 flex-wrap mb-4">
          <h1 class="text-5xl md:text-7xl font-black uppercase tracking-tighter text-white">
            Skills
          </h1>
          <span class="category-badge-ops">// EXPERTISE</span>
        </div>
        <div class="h-0.5 w-48 bg-gradient-to-r from-cyber-magenta to-transparent"></div>
      </div>
      
      <!-- Category Filters -->
      <div class="flex flex-wrap gap-2 mb-8" id="skill-categories">
        {skillCategories.map((category) => (
          <button
            class:list={[
              "cyber-btn px-4 py-2 text-xs font-mono skill-category-btn transition-all",
              category === "All" ? "border-cyber-magenta text-cyber-magenta bg-cyber-magenta/10" : "border-cyber-border text-cyber-text-muted"
            ]}
            data-category={category}
          >
            {category}
          </button>
        ))}
      </div>
      
      <div id="skills-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {skillsData.skills.map((skill, index) => {
          const borderColors = ['border-cyber-cyan/30', 'border-cyber-magenta/30', 'border-cyber-green/30', 'border-cyber-yellow/30'];
          const borderColor = borderColors[index % borderColors.length];
          
          return (
            <div 
              class="skill-item"
              data-category={skill.category}
              data-title={skill.title.toLowerCase()}
              data-description={skill.description.toLowerCase()}
            >
              <div class={`cyber-card border-2 ${borderColor} hover:border-cyber-cyan transition-all duration-300 p-6`}
                   style="box-shadow: 4px 4px 0px 0px #2a2a3a;">
                <div class="flex items-center gap-3 mb-4 border-b border-cyber-border pb-4">
                  <i class={`bx ${skill.icon} text-3xl ${skill.color}`}></i>
                  <h3 class="font-black text-xl uppercase leading-none text-white">{skill.title}</h3>
                </div>
                <p class="text-sm font-medium text-cyber-text leading-relaxed">
                  {skill.description}
                </p>
                <div class="mt-4 flex justify-end">
                  <span class="font-mono text-[10px] uppercase tracking-widest text-cyber-text-muted border border-cyber-border px-2 py-0.5">{skill.category}</span>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>

<script>
  function initSkills() {
    const toolItems = document.querySelectorAll('.tool-item');
    const categoryBtns = document.querySelectorAll('.category-btn');
    const noToolsMsg = document.getElementById('no-tools-found');
    const resetToolsBtn = document.getElementById('reset-tools');
    
    let currentToolCategory = 'All';
    let currentSearchTerm = '';
    let currentProficiency = 0;

    function filterTools() {
      let visibleCount = 0;
      
      toolItems.forEach(item => {
        const el = item as HTMLElement;
        const name = el.dataset.name || '';
        const category = el.dataset.category || '';
        const proficiency = parseInt(el.dataset.proficiency || '0');
        
        const matchesCategory = currentToolCategory === 'All' || category === currentToolCategory;
        const matchesSearch = name.includes(currentSearchTerm.toLowerCase());
        const matchesProficiency = proficiency >= currentProficiency;
        
        if (matchesCategory && matchesSearch && matchesProficiency) {
          el.style.display = '';
          visibleCount++;
        } else {
          el.style.display = 'none';
        }
      });
      
      if (noToolsMsg) {
        noToolsMsg.classList.toggle('hidden', visibleCount > 0);
      }
    }

    categoryBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        categoryBtns.forEach(b => {
          b.classList.remove('border-cyber-cyan', 'text-cyber-cyan', 'bg-cyber-cyan/10');
          b.classList.add('border-cyber-border', 'text-cyber-text-muted');
        });
        btn.classList.add('border-cyber-cyan', 'text-cyber-cyan', 'bg-cyber-cyan/10');
        btn.classList.remove('border-cyber-border', 'text-cyber-text-muted');
        
        currentToolCategory = (btn as HTMLElement).dataset.category || 'All';
        filterTools();
      });
    });

    document.addEventListener('filterChange', (e: any) => {
      const { searchTerm, proficiencyRange } = e.detail;
      if (searchTerm !== undefined) currentSearchTerm = searchTerm;
      if (proficiencyRange !== undefined) currentProficiency = proficiencyRange;
      filterTools();
    });

    resetToolsBtn?.addEventListener('click', () => {
      currentToolCategory = 'All';
      currentSearchTerm = '';
      currentProficiency = 0;
      
      categoryBtns.forEach(b => {
        if ((b as HTMLElement).dataset.category === 'All') {
          b.classList.add('border-cyber-cyan', 'text-cyber-cyan', 'bg-cyber-cyan/10');
          b.classList.remove('border-cyber-border', 'text-cyber-text-muted');
        } else {
          b.classList.remove('border-cyber-cyan', 'text-cyber-cyan', 'bg-cyber-cyan/10');
          b.classList.add('border-cyber-border', 'text-cyber-text-muted');
        }
      });
      
      filterTools();
    });

    // Skill Filters
    const skillItems = document.querySelectorAll('.skill-item');
    const skillCategoryBtns = document.querySelectorAll('.skill-category-btn');
    
    skillCategoryBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        skillCategoryBtns.forEach(b => {
          b.classList.remove('border-cyber-magenta', 'text-cyber-magenta', 'bg-cyber-magenta/10');
          b.classList.add('border-cyber-border', 'text-cyber-text-muted');
        });
        btn.classList.add('border-cyber-magenta', 'text-cyber-magenta', 'bg-cyber-magenta/10');
        btn.classList.remove('border-cyber-border', 'text-cyber-text-muted');
        
        const cat = (btn as HTMLElement).dataset.category || 'All';
        
        skillItems.forEach(item => {
          const el = item as HTMLElement;
          if (cat === 'All' || el.dataset.category === cat) {
            el.style.display = '';
          } else {
            el.style.display = 'none';
          }
        });
      });
    });
  }

  initSkills();
  document.addEventListener('astro:page-load', initSkills);
</script>