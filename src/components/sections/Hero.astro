---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import { heroData } from '../../data/heroData';
import ethanImage from '../../assets/images/ethan.jpg';
---

<section
  id="hero"
  class="min-h-screen flex flex-col justify-center items-center relative pt-20 pb-20 bg-cyber-bg overflow-hidden selection:bg-cyber-magenta/30 selection:text-white scan-lines"
>
  <!-- Grid background -->
  <div class="absolute inset-0 pointer-events-none z-0" style={{
    backgroundImage: `
      linear-gradient(rgba(0, 255, 245, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 255, 245, 0.03) 1px, transparent 1px)
    `,
    backgroundSize: '60px 60px',
  }}></div>

  <!-- Animated gradient orbs -->
  <div class="absolute top-1/4 -left-32 w-96 h-96 bg-cyber-cyan/5 blur-3xl animate-pulse-glow pointer-events-none"></div>
  <div class="absolute bottom-1/4 -right-32 w-96 h-96 bg-cyber-magenta/5 blur-3xl animate-pulse-glow pointer-events-none" style="animation-delay: 1s;"></div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="max-w-7xl mx-auto">
      
      <!-- Main content -->
      <div class="flex flex-col items-center gap-8 md:gap-12">
        
        <!-- Profile Image with neon treatment -->
        <div class="relative group animate-on-scroll slide-down">
          <div class="relative inline-block">
            <!-- Neon glow backdrop -->
            <div class="absolute -inset-2 bg-gradient-to-br from-cyber-cyan/20 to-cyber-magenta/20 blur-lg group-hover:blur-xl transition-all duration-500"></div>
            
            <!-- Main container -->
            <div 
              id="hero-profile-container"
              class="relative w-56 h-56 md:w-72 md:h-72 border-3 border-cyber-cyan overflow-hidden bg-cyber-surface cursor-pointer transition-all duration-300 hover:-translate-y-2 hover:shadow-glow-cyan-lg"
              title="Click me for a surprise 👀"
              style="box-shadow: 0 0 20px rgba(0, 255, 245, 0.3), 6px 6px 0px 0px #2a2a3a;"
            >
              <Image
                id="hero-image"
                src={ethanImage}
                alt="Ethan Cornwill"
                class="object-cover w-full h-full grayscale-[20%] contrast-110"
                loading="eager"
                width={288}
                height={288}
                densities={[1.5, 2]}
              />
              <!-- Scan line overlay on image -->
              <div class="absolute inset-0 bg-gradient-to-b from-transparent via-cyber-cyan/5 to-transparent pointer-events-none"></div>
            </div>
          </div>
        </div>

        <!-- Text content -->
        <div class="flex flex-col gap-6 items-center text-center max-w-4xl animate-on-scroll slide-up">
          
          <!-- Name with glitch -->
          <div class="relative">
            <h1 class="text-6xl md:text-8xl lg:text-9xl font-black uppercase tracking-tighter leading-[0.85] text-white">
              <span class="inline-block">HI,</span>
              <span class="inline-block neon-magenta">I'M</span>
              <br/>
              <span class="relative inline-block glitch-text" data-text="ETHAN">
                ETHAN
                <span class="absolute -bottom-2 left-0 w-full h-2 md:h-3 bg-cyber-cyan -z-10"></span>
              </span>
            </h1>
          </div>
          
          <!-- Title box -->
          <div class="border-2 border-cyber-cyan bg-cyber-surface p-5 md:p-7 max-w-2xl transition-all duration-200 hover:shadow-glow-cyan"
               style="box-shadow: 4px 4px 0px 0px #2a2a3a;">
            <p class="text-2xl md:text-4xl font-black uppercase leading-none text-cyber-cyan tracking-tight glitch-text" data-text="AI ENGINEER & SYSTEMS ARCHITECT">
              AI ENGINEER &<br/>SYSTEMS ARCHITECT
            </p>
          </div>

          <!-- Bio statement -->
          <div class="border-2 border-cyber-border bg-cyber-surface/80 p-5 md:p-7 max-w-3xl transition-all duration-200"
               style="box-shadow: 4px 4px 0px 0px #2a2a3a;">
            <p class="text-lg md:text-xl font-medium leading-relaxed text-cyber-text">
              13+ years building software. 10 years managing operations.
              <br/>
              <span class="bg-cyber-cyan/10 text-cyber-cyan px-2 py-0.5 inline-block mt-2 font-bold border border-cyber-cyan/30">Now I architect AI systems that survive production,</span>
              <br/>
              <span class="text-cyber-text-muted">not just demos that die in staging.</span>
            </p>
          </div>
          
          <!-- Rotating role display -->
          <div class="border-2 border-cyber-magenta bg-cyber-surface p-5 md:p-7 w-full max-w-2xl transition-all duration-200"
               style="box-shadow: 4px 4px 0px 0px rgba(255, 0, 255, 0.3);">
            <h2 class="text-xl md:text-3xl font-black uppercase min-h-[50px] md:min-h-[60px] flex items-center justify-center neon-magenta font-mono">
              <span class="text-cyber-text-muted mr-2">&gt;</span>
              <span id="typing-text"></span>
              <span class="animate-blink inline-block w-2 h-7 md:h-10 ml-1 bg-cyber-magenta"></span>
            </h2>
          </div>

          <!-- Skill tags -->
          <div class="flex flex-wrap justify-center gap-3 mt-6">
            <div class="cyber-btn border-cyber-cyan text-cyber-cyan px-6 py-3 text-sm md:text-base font-mono hover:bg-cyber-cyan/10 transition-all duration-200">
              AI DEVELOPMENT
            </div>
            <div class="cyber-btn border-cyber-green text-cyber-green px-6 py-3 text-sm md:text-base font-mono hover:bg-cyber-green/10 transition-all duration-200">
              AGENT SYSTEMS
            </div>
            <div class="cyber-btn border-cyber-magenta text-cyber-magenta px-6 py-3 text-sm md:text-base font-mono hover:bg-cyber-magenta/10 transition-all duration-200">
              PRODUCTION ML
            </div>
          </div>
        </div>
      </div>

      <!-- Social links -->
      <div class="mt-16 flex justify-center gap-4 flex-wrap animate-on-scroll slide-up">
        <a href="https://github.com/finneh4249" target="_blank" rel="noopener noreferrer"
          class="cyber-btn border-cyber-border w-16 h-16 md:w-20 md:h-20 p-0 flex items-center justify-center hover:border-white hover:text-white hover:shadow-glow-cyan transition-all group">
          <Icon name="mdi:github" class="text-4xl md:text-5xl text-cyber-text-muted group-hover:text-white transition-colors" />
        </a>
        <a href="https://x.com/FinnehReform" target="_blank" rel="noopener noreferrer"
          class="cyber-btn border-cyber-border w-16 h-16 md:w-20 md:h-20 p-0 flex items-center justify-center hover:border-cyber-cyan hover:text-cyber-cyan hover:shadow-glow-cyan transition-all group">
          <Icon name="mdi:twitter" class="text-4xl md:text-5xl text-cyber-text-muted group-hover:text-cyber-cyan transition-colors" />
        </a>
        <a href="https://www.linkedin.com/in/ethan-cornwill/" target="_blank" rel="noopener noreferrer"
          class="cyber-btn border-cyber-border w-16 h-16 md:w-20 md:h-20 p-0 flex items-center justify-center hover:border-cyber-blue hover:text-cyber-blue hover:shadow-glow-cyan transition-all group">
          <Icon name="mdi:linkedin" class="text-4xl md:text-5xl text-cyber-text-muted group-hover:text-cyber-blue transition-colors" />
        </a>
        <a href="https://cityloopers.com/discord" target="_blank" rel="noopener noreferrer"
          class="cyber-btn border-cyber-border w-16 h-16 md:w-20 md:h-20 p-0 flex items-center justify-center hover:border-cyber-purple hover:text-cyber-purple hover:shadow-glow-magenta transition-all group">
          <Icon name="mdi:discord" class="text-4xl md:text-5xl text-cyber-text-muted group-hover:text-cyber-purple transition-colors" />
        </a>
      </div>

      <!-- Scroll indicator -->
      <div class="mt-16 text-center animate-on-scroll slide-up">
        <a href="#projects" class="cyber-btn-primary px-8 py-4 inline-flex items-center gap-3 animate-bounce text-base group">
          <span class="font-mono font-bold uppercase">VIEW PROJECTS</span>
          <span class="text-2xl group-hover:translate-y-1 transition-transform">↓</span>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Data injection -->
<div id="hero-data" data-strings={JSON.stringify(heroData.typingStrings)} data-facts={JSON.stringify(heroData.funFacts)} class="hidden"></div>

<style>
  .shadow-brutal-xxl {
    box-shadow: 12px 12px 0px 0px #2a2a3a, 0 0 30px rgba(0, 255, 245, 0.1);
  }

  .shake-animation {
    animation: shake 0.5s;
  }

  @keyframes shake {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    10% { transform: translate(-2px, -2px) rotate(-2deg); }
    20% { transform: translate(2px, -2px) rotate(2deg); }
    30% { transform: translate(-2px, 2px) rotate(-2deg); }
    40% { transform: translate(2px, 2px) rotate(2deg); }
    50% { transform: translate(-2px, -2px) rotate(-2deg); }
    60% { transform: translate(2px, 2px) rotate(2deg); }
    70% { transform: translate(-2px, 2px) rotate(-2deg); }
    80% { transform: translate(2px, -2px) rotate(2deg); }
    90% { transform: translate(-2px, -2px) rotate(-2deg); }
  }
</style>

<script>
  function initHero() {
    const typingText = document.getElementById('typing-text');
    const heroDataEl = document.getElementById('hero-data');
    if (!heroDataEl) return;
    const strings = JSON.parse(heroDataEl.dataset.strings || '[]');
    
    if (typingText) {
      const typeElement = typingText as HTMLElement;
      if (typeElement.dataset.initialized === 'true') return;

      let stringIndex = 0;
      let charIndex = 0;
      let isDeleting = false;

      function type() {
        const currentString = strings[stringIndex];
        
        if (isDeleting) {
          typeElement.textContent = currentString.substring(0, charIndex - 1);
          charIndex--;
        } else {
          typeElement.textContent = currentString.substring(0, charIndex + 1);
          charIndex++;
        }

        let typeSpeed = 80;
        if (isDeleting) typeSpeed = 40;

        if (!isDeleting && charIndex === currentString.length) {
          typeSpeed = 2000;
          isDeleting = true;
        } else if (isDeleting && charIndex === 0) {
          isDeleting = false;
          stringIndex = (stringIndex + 1) % strings.length;
          typeSpeed = 500;
        }

        setTimeout(type, typeSpeed);
      }

      type();
      typeElement.dataset.initialized = 'true';
    }

    // Easter Egg: Image Click
    const profileContainer = document.getElementById('hero-profile-container');
    const heroImage = document.getElementById('hero-image');

    if (profileContainer && heroImage && !profileContainer.dataset.hasListener) {
      const funFacts = JSON.parse(heroDataEl.dataset.facts || '[]');
      
      const clickHandler = () => {
        const randomFact = funFacts[Math.floor(Math.random() * funFacts.length)];
        
        const notification = document.createElement('div');
        notification.innerHTML = randomFact;
        notification.style.cssText = `
          position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);
          background: #12121a; color: #00fff5; padding: 1.5rem 2rem;
          border: 2px solid #00fff5; box-shadow: 0 0 20px rgba(0, 255, 245, 0.3), 6px 6px 0px 0px #2a2a3a;
          z-index: 10000; font-weight: bold; font-size: 16px;
          max-width: 90vw; width: 500px; text-align: center;
          font-family: 'JetBrains Mono', 'Space Mono', monospace;
        `;
        
        document.body.appendChild(notification);
        
        setTimeout(() => {
          notification.style.transition = 'all 0.3s ease';
          notification.style.opacity = '0';
          notification.style.transform = 'translate(-50%, -50%) scale(0) rotate(180deg)';
          setTimeout(() => notification.remove(), 300);
        }, 3000);
        
        heroImage.classList.add('shake-animation');
        setTimeout(() => heroImage.classList.remove('shake-animation'), 500);
      };
      
      profileContainer.addEventListener('click', clickHandler);
      profileContainer.dataset.hasListener = 'true';
    }
  }

  initHero();
  document.addEventListener('astro:page-load', initHero);
</script>