---
import testimonialsData from '../../data/testimonials.json';
import { Icon } from 'astro-icon/components';

interface Testimonial {
  name: string;
  position: string;
  company?: string;
  testimonial: string;
  avatar?: string;
}

const testimonials = (Array.isArray(testimonialsData) ? testimonialsData : []) as Testimonial[];
---

<section id="testimonials" class="py-20 bg-cyber-bg relative overflow-hidden">
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-cyber-purple/3 blur-3xl pointer-events-none"></div>
  
  <div class="container mx-auto px-4 md:px-6 relative z-10">
    <div class="mb-12 animate-on-scroll slide-up">
      <div class="flex items-center justify-center gap-4 flex-wrap mb-4">
        <h2 class="text-5xl md:text-7xl font-black uppercase tracking-tighter text-white">
          Testimonials
        </h2>
        <span class="category-badge-ops">// REVIEWS</span>
      </div>
      <div class="h-0.5 w-48 bg-gradient-to-r from-transparent via-cyber-purple to-transparent mx-auto"></div>
    </div>

    {testimonials.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
        {testimonials.map((testimonial, index) => {
          const borderColors = ['border-cyber-cyan/30', 'border-cyber-magenta/30', 'border-cyber-green/30'];
          const borderColor = borderColors[index % borderColors.length];
          
          return (
            <div class={`cyber-card ${borderColor} border-2 hover:border-cyber-cyan transition-all animate-on-scroll slide-up`}
                 style={{ 'animation-delay': `${index * 0.1}s`, 'box-shadow': '4px 4px 0px 0px #2a2a3a' }}>
              <div class="p-5">
                <div class="flex items-center mb-4">
                  {testimonial.avatar ? (
                    <div class="w-12 h-12 border border-cyber-border mr-3 overflow-hidden bg-cyber-surface">
                      <img
                        src={testimonial.avatar}
                        alt={`${testimonial.name}'s avatar`}
                        class="w-full h-full object-cover"
                        onerror={`this.onerror=null;this.src='https://ui-avatars.com/api/?name=${encodeURIComponent(testimonial.name)}&background=12121a&color=00fff5'`}
                      />
                    </div>
                  ) : (
                    <div class="w-12 h-12 border border-cyber-cyan mr-3 bg-cyber-cyan/10 flex items-center justify-center font-mono font-bold text-sm text-cyber-cyan">
                      {testimonial.name.split(' ').map(word => word[0]).join('')}
                    </div>
                  )}
                  <div>
                    <h3 class="font-bold text-sm uppercase text-white">{testimonial.name}</h3>
                    <p class="text-xs font-mono text-cyber-text-muted">{testimonial.position}</p>
                    {testimonial.company && (
                      <p class="text-[10px] font-mono text-cyber-text-muted">{testimonial.company}</p>
                    )}
                  </div>
                </div>
                <p class="text-sm font-medium leading-relaxed border-l-2 border-cyber-cyan/30 pl-3 text-cyber-text">"{testimonial.testimonial}"</p>
              </div>
            </div>
          );
        })}
      </div>
    ) : (
      <div class="max-w-3xl mx-auto mb-12 cyber-card border-2 border-cyber-border hover:border-cyber-purple transition-all animate-on-scroll slide-up"
           style="box-shadow: 4px 4px 0px 0px #2a2a3a;">
        <div class="p-10 text-center">
          <div class="w-16 h-16 border border-cyber-purple flex items-center justify-center mx-auto mb-4">
            <Icon name="mdi:message-text" class="text-3xl text-cyber-purple" />
          </div>
          <h3 class="text-2xl font-bold uppercase mb-3 text-white font-mono">// Coming Soon</h3>
          <p class="text-sm font-medium text-cyber-text-muted">
            Currently collecting feedback from clients and colleagues.
            <br />Check back soon!
          </p>
        </div>
      </div>
    )}
    
    <div class="max-w-3xl mx-auto cyber-card border-2 border-cyber-purple/30 hover:border-cyber-purple transition-all animate-on-scroll slide-up"
         style="box-shadow: 4px 4px 0px 0px rgba(183, 92, 255, 0.15);">
      <div class="p-8 text-center">
        <h3 class="text-xl font-bold uppercase mb-3 text-white font-mono">// Worked with me before?</h3>
        <p class="text-sm font-medium max-w-xl mx-auto mb-6 text-cyber-text-muted">
          I'd love to hear about your experience. Your feedback helps me improve.
        </p>
        <a 
          href="mailto:mail@finneh.xyz?subject=Testimonial for Ethan Cornwill&body=Hi Ethan, I'd like to share my experience working with you..."
          class="cyber-btn-magenta px-6 py-3 text-sm inline-flex items-center gap-2"
        >
          <Icon name="mdi:message-text" class="text-lg" />
          <span class="font-mono font-bold uppercase">Share Your Experience</span>
        </a>
      </div>
    </div>
  </div>
</section>