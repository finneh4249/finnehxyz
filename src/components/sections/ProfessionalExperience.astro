---
import TimelineItem from '../professional-experience/TimelineItem.astro';
import experienceData from '../../data/experience.json';
import type { ImageMetadata } from 'astro';

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/*.{jpeg,jpg,png,gif,webp}', { eager: true });

const getImagePath = (path: string) => {
  if (!path) return undefined;
  const normalizedPath = path.replace(/^(\.\/)?images\//, '/src/assets/images/');
  return images[normalizedPath]?.default;
};

const experiences: any[] = experienceData;
const techExperiences = experiences.filter(e => e.category === 'technology');
const opsExperiences = experiences.filter(e => e.category === 'operations');
---

<section id="professionalExperience" class="py-20 bg-cyber-surface relative overflow-hidden">
  <!-- Background accents -->
  <div class="absolute top-0 left-0 w-96 h-96 bg-cyber-cyan/3 blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 right-0 w-96 h-96 bg-cyber-magenta/3 blur-3xl pointer-events-none"></div>
  
  <div class="container mx-auto px-4 relative z-10">
    <!-- Section header -->
    <div class="mb-12 animate-on-scroll slide-right">
      <div class="flex items-center gap-4 flex-wrap mb-4">
        <h2 class="text-5xl md:text-7xl font-black uppercase tracking-tighter text-white">
          Experience
        </h2>
        <span class="category-badge-ops">// WORK</span>
      </div>
      <div class="h-0.5 w-48 bg-gradient-to-r from-cyber-magenta to-transparent"></div>
    </div>

    <!-- Category Tabs -->
    <div class="flex gap-2 mb-10" id="experience-tabs">
      <button 
        class="exp-tab cyber-btn border-cyber-cyan text-cyber-cyan bg-cyber-cyan/10 px-6 py-3 text-sm font-mono" 
        data-tab="technology"
      >
        &lt;TECHNOLOGY /&gt;
      </button>
      <button 
        class="exp-tab cyber-btn border-cyber-border text-cyber-text-muted px-6 py-3 text-sm font-mono" 
        data-tab="operations"
      >
        &lt;OPERATIONS /&gt;
      </button>
    </div>

    <!-- Technology Panel -->
    <div id="panel-technology" class="exp-panel space-y-6">
      {techExperiences.map((item, index) => (
        <TimelineItem
          yearRange={item.yearRange}
          company={item.company}
          employer={item.employer}
          roles={item.roles}
          logoSrc={getImagePath(item.logoSrc)}
          logoSrcs={item.logoSrcs?.map((src: string) => getImagePath(src))}
          logoAlt={item.logoAlt}
          index={index}
          isFirst={index === 0}
          isLast={index === techExperiences.length - 1}
          category="technology"
        />
      ))}
    </div>

    <!-- Operations Panel -->
    <div id="panel-operations" class="exp-panel space-y-6 hidden">
      {opsExperiences.map((item, index) => (
        <TimelineItem
          yearRange={item.yearRange}
          company={item.company}
          employer={item.employer}
          roles={item.roles}
          logoSrc={getImagePath(item.logoSrc)}
          logoSrcs={item.logoSrcs?.map((src: string) => getImagePath(src))}
          logoAlt={item.logoAlt}
          index={index}
          isFirst={index === 0}
          isLast={index === opsExperiences.length - 1}
          category="operations"
        />
      ))}
    </div>
  </div>
</section>

<script>
  function initExperience() {
    const tabs = document.querySelectorAll('.exp-tab');
    const panels = document.querySelectorAll('.exp-panel');
    
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = (tab as HTMLElement).dataset.tab;
        
        // Update tabs
        tabs.forEach(t => {
          t.classList.remove('border-cyber-cyan', 'text-cyber-cyan', 'bg-cyber-cyan/10', 'border-cyber-magenta', 'text-cyber-magenta', 'bg-cyber-magenta/10');
          t.classList.add('border-cyber-border', 'text-cyber-text-muted');
        });
        
        if (target === 'technology') {
          tab.classList.add('border-cyber-cyan', 'text-cyber-cyan', 'bg-cyber-cyan/10');
        } else {
          tab.classList.add('border-cyber-magenta', 'text-cyber-magenta', 'bg-cyber-magenta/10');
        }
        tab.classList.remove('border-cyber-border', 'text-cyber-text-muted');
        
        // Update panels
        panels.forEach(p => p.classList.add('hidden'));
        document.getElementById(`panel-${target}`)?.classList.remove('hidden');
      });
    });
  }

  initExperience();
  document.addEventListener('astro:page-load', initExperience);
</script>