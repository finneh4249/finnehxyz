---
---

<section id="aboutme" class="py-20 bg-cyber-bg relative overflow-hidden scan-lines">
  <!-- Background accents -->
  <div class="absolute top-1/2 -left-48 w-96 h-96 bg-cyber-cyan/3 blur-3xl pointer-events-none"></div>
  <div class="absolute top-0 right-0 w-96 h-96 bg-cyber-magenta/3 blur-3xl pointer-events-none"></div>
  
  <div class="container mx-auto px-4 relative z-10">
    <!-- Section header -->
    <div class="mb-16 animate-on-scroll slide-right">
      <div class="flex items-center gap-4 flex-wrap mb-4">
        <h1 class="text-5xl md:text-7xl font-black uppercase tracking-tighter text-white">
          About Me
        </h1>
        <span class="category-badge-tech">// WHO AM I?</span>
      </div>
      <div class="h-0.5 w-48 bg-gradient-to-r from-cyber-cyan to-transparent"></div>
    </div>
    
    <!-- Grid Layout -->
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-6">
      
      <!-- Card 1: The Hook -->
      <div class="animate-on-scroll slide-up">
        <div class="cyber-card border-2 border-cyber-border hover:border-cyber-cyan transition-all duration-300 p-7" style="box-shadow: 4px 4px 0px 0px #2a2a3a;">
          <h3 class="text-2xl mb-4 font-black uppercase text-white leading-none">
            I Build AI Systems That <span class="neon-magenta">Ship</span>
          </h3>
          <p class="text-lg leading-relaxed font-medium text-cyber-text">
            Not demos. Not prototypes. Production systems handling real traffic.
          </p>
        </div>
      </div>
      
      <!-- Card 2: The Experience -->
      <div class="animate-on-scroll slide-up" style="animation-delay: 0.1s">
        <div class="cyber-card border-2 border-cyber-magenta/30 hover:border-cyber-magenta transition-all duration-300 p-7" style="box-shadow: 4px 4px 0px 0px rgba(255, 0, 255, 0.15);">
          <p class="text-base leading-relaxed font-medium text-cyber-text">
            I've spent 13+ years writing code and 10 years managing operations where downtime costs money and failures are public. That combination taught me something most AI engineers miss: the gap between "works on my machine" and "works under load with actual users."
          </p>
        </div>
      </div>

      <!-- Card 3: The Skills -->
      <div class="animate-on-scroll slide-up" style="animation-delay: 0.2s">
        <div class="cyber-card border-2 border-cyber-border hover:border-cyber-green transition-all duration-300 p-7" style="box-shadow: 4px 4px 0px 0px #2a2a3a;">
          <p class="text-base leading-relaxed font-medium text-cyber-text">
            I train LLMs at DataAnnotation. I evaluate model reasoning. I debug AI logic errors. I build RAG pipelines and agent systems. I deploy full-stack applications. All while maintaining ethical practices and radical transparency.
          </p>
        </div>
      </div>

      <!-- Card 4: SPARC -->
      <div class="animate-on-scroll slide-up" style="animation-delay: 0.3s">
        <div class="cyber-card border-2 border-cyber-cyan/30 hover:border-cyber-cyan transition-all duration-300 p-7" style="box-shadow: 4px 4px 0px 0px rgba(0, 255, 245, 0.15);">
          <p class="text-xl font-black uppercase leading-tight neon-cyan mb-3">
            I wrote SPARC — 3,000+ line prompt library.
          </p>
          <p class="text-base text-cyber-text font-medium">
            12 specialized agents, security mandates, TDD workflows. Reduces scaffolding from 2 days to 4-6 hours. Not a framework. A way to encode production engineering into prompts.
          </p>
        </div>
      </div>

      <!-- Card 5: What I'm Shipping (Full Width) -->
      <div class="md:col-span-2 animate-on-scroll slide-up" style="animation-delay: 0.4s">
        <div class="cyber-card border-2 border-cyber-border hover:border-cyber-cyan transition-all duration-300 p-7" style="box-shadow: 4px 4px 0px 0px #2a2a3a;">
          <p class="font-mono font-bold uppercase mb-4 text-lg text-cyber-cyan">// What I'm Shipping</p>
          <div class="grid md:grid-cols-2 gap-6">
            <div class="relative">
              <div class="absolute left-0 top-0 w-0.5 h-full bg-cyber-magenta"></div>
              <div class="pl-4">
                <strong class="text-base text-white">SPARC Prompt Library</strong>
                <p class="mt-1 text-sm font-medium text-cyber-text-muted">Built Fusion, MagnetLab projects, this portfolio.</p>
              </div>
            </div>
            <div class="relative">
              <div class="absolute left-0 top-0 w-0.5 h-full bg-cyber-green"></div>
              <div class="pl-4">
                <strong class="text-base text-white">Fusion Infrastructure</strong>
                <p class="mt-1 text-sm font-medium text-cyber-text-muted">Architected compliance systems for real political organization.</p>
              </div>
            </div>
          </div>
          
          <div class="mt-6">
            <a href="#projects" class="cyber-btn-primary px-6 py-3 text-sm inline-flex items-center gap-2">
              <span class="font-mono font-bold uppercase">See My Work</span>
              <span class="text-lg">→</span>
            </a>
          </div>
        </div>
      </div>
      
      <!-- Transparency Badge -->
      <div class="md:col-span-2 animate-on-scroll slide-up" style="animation-delay: 0.5s">
        <div 
          id="transparency-card"
          class="cyber-card border border-cyber-green/30 hover:border-cyber-green transition-all cursor-pointer p-4"
          title="Click me! 🎯"
          style="box-shadow: 0 0 10px rgba(57, 255, 20, 0.1);"
        >
          <p class="text-xs font-mono text-cyber-green text-center">
            <strong class="uppercase">// Full Transparency:</strong>
            Built with AI-human collaboration. Showing the work, not hiding the tools.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initAboutMe() {
    const transparencyCard = document.getElementById('transparency-card');
    if (transparencyCard) {
      transparencyCard.addEventListener('click', () => {
        const messages = [
          '🎯 Fun fact: This portfolio took ~4 hours to build with SPARC prompt library + Roo Code!',
          '🤖 I wrote the prompts. Roo Code executed them. Claude/GPT validated output.',
          '✨ That\'s the power of systematic prompt architecture!',
          '📊 Traditional build time would\'ve been 2+ weeks.',
          '⚡ Prompt engineering at scale isn\'t just faster. It\'s systematic.',
        ];
        
        const randomMsg = messages[Math.floor(Math.random() * messages.length)];
        
        const notification = document.createElement('div');
        notification.innerHTML = randomMsg;
        notification.style.cssText = `
          position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);
          background: #12121a; color: #39ff14; padding: 1.5rem 2rem;
          border: 2px solid #39ff14; box-shadow: 0 0 20px rgba(57, 255, 20, 0.3), 6px 6px 0px 0px #2a2a3a;
          z-index: 10000; font-weight: bold; font-size: 14px;
          max-width: 400px; text-align: center;
          font-family: 'JetBrains Mono', monospace;
        `;
        
        document.body.appendChild(notification);
        
        setTimeout(() => {
          notification.style.transition = 'all 0.3s ease';
          notification.style.opacity = '0';
          notification.style.transform = 'translate(-50%, -50%) scale(0)';
          setTimeout(() => notification.remove(), 300);
        }, 2500);
      });
    }
  }
  
  initAboutMe();
  document.addEventListener('astro:page-load', initAboutMe);
</script>