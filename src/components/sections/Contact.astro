---
---

<section id="contact" class="py-20 bg-cyber-bg relative overflow-hidden scan-lines">
  <!-- Background accents -->
  <div class="absolute top-0 left-0 w-96 h-96 bg-cyber-cyan/3 blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 right-0 w-96 h-96 bg-cyber-magenta/3 blur-3xl pointer-events-none"></div>
  
  <div class="container mx-auto px-4 relative z-10">
    <div class="mb-12 animate-on-scroll slide-up">
      <div class="flex items-center justify-center gap-4 flex-wrap mb-4">
        <span class="category-badge-ops">// LET'S BUILD</span>
        <h2 class="text-5xl md:text-7xl font-black uppercase tracking-tighter neon-magenta">
          Contact
        </h2>
      </div>
      <div class="h-0.5 w-48 bg-gradient-to-r from-transparent via-cyber-magenta to-transparent mx-auto"></div>
    </div>
    
    <p class="text-center text-lg font-medium max-w-2xl mx-auto mb-4 text-cyber-text">
      Need an AI engineer who actually ships production systems?
    </p>
    
    <p class="text-center text-sm max-w-2xl mx-auto mb-4 text-cyber-text-muted font-mono">
      // Currently in retail management at Aldi, actively seeking AI engineering roles.<br/>
      // Available to start with standard notice period.
    </p>
    
    <p class="text-center text-lg font-bold mb-12 text-cyber-text">
      Let's talk:{' '}
      <a 
        href="mailto:mail@finneh.xyz" 
        class="neon-cyan hover:underline transition-all"
      >
        mail@finneh.xyz
      </a>
    </p>
    
    <div class="max-w-5xl mx-auto grid md:grid-cols-3 gap-6">
      <!-- Form -->
      <div class="md:col-span-2 animate-on-scroll slide-right">
        <div class="cyber-card border-2 border-cyber-border hover:border-cyber-cyan/30 transition-all"
             style="box-shadow: 4px 4px 0px 0px #2a2a3a;">
          <div class="p-6 md:p-8">
            <div class="font-mono text-xs text-cyber-cyan mb-4">// contact_form.init()</div>
            
            <div id="success-message" class="cyber-card border border-cyber-green p-8 text-center hidden">
              <div class="flex flex-col items-center">
                <div class="w-16 h-16 border border-cyber-green flex items-center justify-center mb-4">
                  <span class="text-3xl neon-green">✓</span>
                </div>
                <h3 class="text-xl font-bold uppercase mb-2 neon-green font-mono">Message Sent!</h3>
                <p class="text-sm text-cyber-text">Thanks! I'll get back to you soon.</p>
              </div>
            </div>

            <form id="contact-form" class="space-y-5">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                  <label class="font-mono text-xs uppercase mb-2 block text-cyber-text-muted tracking-widest">
                    Full Name
                  </label>
                  <input
                    type="text"
                    name="name"
                    class="cyber-input"
                    placeholder="> your name"
                    required
                  />
                </div>
                
                <div>
                  <label class="font-mono text-xs uppercase mb-2 block text-cyber-text-muted tracking-widest">
                    Email Address
                  </label>
                  <input
                    type="email"
                    name="email"
                    class="cyber-input"
                    placeholder="> your@email.com"
                    required
                  />
                </div>
              </div>
              
              <div>
                <label class="font-mono text-xs uppercase mb-2 block text-cyber-text-muted tracking-widest">
                  Subject
                </label>
                <input
                  type="text"
                  name="subject"
                  class="cyber-input"
                  placeholder="> what's this about?"
                  required
                />
              </div>
              
              <div>
                <label class="font-mono text-xs uppercase mb-2 block text-cyber-text-muted tracking-widest">
                  Message
                </label>
                <textarea
                  name="message"
                  class="cyber-input h-36 resize-none"
                  placeholder="> tell me about your project..."
                  required
                ></textarea>
              </div>
              
              <div id="error-message" class="border border-cyber-pink bg-cyber-pink/10 p-4 font-mono text-sm text-cyber-pink hidden">
                // ERROR: Failed to send message. Please try again later.
              </div>
              
              <div class="flex justify-center mt-6">
                <button
                  type="submit"
                  id="submit-btn"
                  class="cyber-btn-primary px-10 py-4 text-base font-mono disabled:opacity-50 disabled:cursor-not-allowed"
                >
                  TRANSMIT_MESSAGE()
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>

      <!-- Contact cards -->
      <div class="space-y-4 animate-on-scroll slide-left">
        <div class="cyber-card border border-cyber-border hover:border-cyber-cyan transition-all p-5 text-center"
             style="box-shadow: 3px 3px 0px 0px #2a2a3a;">
          <div class="w-12 h-12 border border-cyber-cyan mx-auto mb-3 flex items-center justify-center">
            <span class="text-2xl">📧</span>
          </div>
          <h3 class="text-base font-bold uppercase mb-1 text-white font-mono">Email</h3>
          <a 
            href="mailto:mail@finneh.xyz" 
            class="text-sm font-mono text-cyber-cyan hover:underline"
          >
            mail@finneh.xyz
          </a>
        </div>
        
        <div class="cyber-card border border-cyber-border hover:border-cyber-blue transition-all p-5 text-center"
             style="box-shadow: 3px 3px 0px 0px #2a2a3a;">
          <div class="w-12 h-12 border border-cyber-blue mx-auto mb-3 flex items-center justify-center">
            <i class="bx bxl-linkedin text-2xl text-cyber-blue"></i>
          </div>
          <h3 class="text-base font-bold uppercase mb-1 text-white font-mono">LinkedIn</h3>
          <a 
            href="https://www.linkedin.com/in/ethancornwill/" 
            target="_blank" 
            rel="noopener noreferrer"
            class="text-sm font-mono text-cyber-blue hover:underline"
          >
            Connect
          </a>
        </div>
        
        <div class="cyber-card border border-cyber-border hover:border-white transition-all p-5 text-center"
             style="box-shadow: 3px 3px 0px 0px #2a2a3a;">
          <div class="w-12 h-12 border border-cyber-border mx-auto mb-3 flex items-center justify-center">
            <i class="bx bxl-github text-2xl text-white"></i>
          </div>
          <h3 class="text-base font-bold uppercase mb-1 text-white font-mono">GitHub</h3>
          <a 
            href="https://github.com/finneh4249" 
            target="_blank" 
            rel="noopener noreferrer"
            class="text-sm font-mono text-cyber-text-muted hover:text-white hover:underline"
          >
            Follow
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initContact() {
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const successMsg = document.getElementById('success-message');
    const errorMsg = document.getElementById('error-message');
    const submitBtn = document.getElementById('submit-btn');

    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (submitBtn) {
          submitBtn.textContent = 'TRANSMITTING...';
          (submitBtn as HTMLButtonElement).disabled = true;
        }
        errorMsg?.classList.add('hidden');

        try {
          await new Promise(resolve => setTimeout(resolve, 1500));
          
          form.classList.add('hidden');
          successMsg?.classList.remove('hidden');
          form.reset();
          
          setTimeout(() => {
            successMsg?.classList.add('hidden');
            form.classList.remove('hidden');
            if (submitBtn) {
              submitBtn.textContent = 'TRANSMIT_MESSAGE()';
              (submitBtn as HTMLButtonElement).disabled = false;
            }
          }, 5000);
          
        } catch (err) {
          console.error('Form error:', err);
          errorMsg?.classList.remove('hidden');
          if (submitBtn) {
            submitBtn.textContent = 'TRANSMIT_MESSAGE()';
            (submitBtn as HTMLButtonElement).disabled = false;
          }
        }
      });
    }
  }

  initContact();
  document.addEventListener('astro:page-load', initContact);
</script>