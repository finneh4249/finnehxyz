---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSectionMeta } from '../../utils/seo';

const seoMeta = getSectionMeta('blog');

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function isoDate(date: Date) {
  return date.toISOString().slice(0, 10);
}
---

<BaseLayout title={seoMeta.title} description={seoMeta.description}>
  <div class="signal-grid-bg" aria-hidden="true"></div>

  <!-- Navigation -->
  <nav class="fixed top-0 left-0 right-0 z-50 flex justify-between items-center px-6 md:px-12 py-3 bg-signal-black/95 border-b border-signal-white/8 backdrop-blur-sm" role="navigation" aria-label="Main Navigation">
    <a href="/" class="font-display font-black text-lg text-signal-white tracking-tighter uppercase flex items-center border-2 border-signal-orange px-4 py-1 hover:bg-signal-orange hover:text-signal-black transition-colors duration-200">
      ETHAN CORNWILL
    </a>
    <div class="flex items-center gap-8 md:gap-12">
      <a href="/resume" class="font-mono text-[10px] uppercase tracking-[0.4em] text-signal-white/50 hover:text-signal-white transition-colors">Resume</a>
      <a href="/blog" class="font-mono text-[10px] uppercase tracking-[0.4em] text-signal-orange hover:text-signal-white transition-colors">Blog</a>
    </div>
  </nav>

  <main class="pt-[52px] min-h-screen">

    <!-- Header band -->
    <div class="surface-orange px-6 md:px-12 py-8 md:py-12">
      <div class="max-w-[1800px] mx-auto flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
          <p class="font-mono text-signal-black/60 text-xs uppercase tracking-[0.5em] mb-2">
            <a href="/" class="hover:text-signal-black transition-colors">Home</a>
            <span class="mx-2 opacity-40">/</span>
            Blog
          </p>
          <h1 class="text-signal-black tracking-tighter leading-none" style="font-size:clamp(2.5rem,7vw,8rem)">
            Dispatch
          </h1>
        </div>
        <p class="text-signal-black/60 font-mono text-xs max-w-xs leading-relaxed">
          {sortedPosts.length} {sortedPosts.length === 1 ? 'entry' : 'entries'} — AI engineering, prompt architecture, and production systems.
        </p>
      </div>
    </div>

    <!-- Posts grid -->
    <div class="px-6 md:px-12 py-12">
      <div class="max-w-[1800px] mx-auto">

        {sortedPosts.length === 0 ? (
          <div class="py-24 text-center">
            <p class="font-mono text-sm text-signal-white/30 uppercase tracking-[0.35em]">
              // buffer empty — no entries found
            </p>
          </div>
        ) : (
          <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
            {sortedPosts.map((post) => (
              <article class="bg-signal-charcoal border border-signal-white/10 hover:-translate-y-0.5 hover:shadow-signal-orange transition-all duration-200 group flex flex-col">
                <a href={`/blog/${post.id}`} class="block p-6 flex flex-col flex-1">

                  <!-- Date + primary tag -->
                  <div class="flex items-center justify-between mb-4">
                    <time
                      class="font-mono text-[10px] uppercase tracking-[0.35em] text-signal-white/40"
                      datetime={post.data.pubDate.toISOString()}
                    >
                      {isoDate(post.data.pubDate)}
                    </time>
                    {post.data.tags?.[0] && (
                      <span class="committed-cyan text-[9px] font-mono uppercase tracking-[0.2em] text-signal-cyan px-2 py-0.5">
                        {post.data.tags[0]}
                      </span>
                    )}
                  </div>

                  <!-- Title -->
                  <h2 class="text-signal-white group-hover:text-signal-orange transition-colors mb-3 leading-tight not-italic" style="font-size:clamp(1.05rem,1.8vw,1.35rem)">
                    {post.data.title}
                  </h2>

                  <!-- Description -->
                  <p class="text-signal-white/55 text-sm leading-relaxed line-clamp-3 mb-5 flex-1">
                    {post.data.description}
                  </p>

                  <!-- Secondary tags -->
                  {post.data.tags && post.data.tags.length > 1 && (
                    <div class="flex flex-wrap gap-1.5 mb-4">
                      {post.data.tags.slice(1, 4).map((tag: string) => (
                        <span class="text-[9px] font-mono uppercase tracking-wider text-signal-white/35 border border-signal-white/12 px-1.5 py-0.5">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}

                  <!-- CTA -->
                  <div class="flex items-center gap-2 font-mono text-xs text-signal-orange group-hover:gap-3 transition-all">
                    <span>→</span>
                    <span>read_entry()</span>
                  </div>

                </a>
              </article>
            ))}
          </div>
        )}

        <!-- Back -->
        <div class="mt-12 text-center">
          <a href="/" class="font-mono text-xs text-signal-white/40 hover:text-signal-orange transition-colors">
            ← back to home
          </a>
        </div>

      </div>
    </div>

  </main>
</BaseLayout>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
