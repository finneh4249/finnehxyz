---
import BaseLayout from '../layouts/BaseLayout.astro';
import experienceData from '../data/experience.json';
import skillsData from '../data/skills.json';
import educationItems from '../data/education.json';
import { projects } from '../data/projects';

const techRoles = (experienceData as any[]).filter(e => e.category === 'technology');
const opsRoles  = (experienceData as any[]).filter(e => e.category === 'operations');

const topTools = skillsData.tools
  .sort((a, b) => b.proficiency - a.proficiency)
  .slice(0, 20);

const toolsByCategory = topTools.reduce((acc: Record<string, string[]>, tool) => {
  if (!acc[tool.category]) acc[tool.category] = [];
  acc[tool.category].push(tool.name);
  return acc;
}, {} as Record<string, string[]>);

const keyEdu = educationItems.filter(e =>
  e.program.includes('Diploma') || e.program.includes('VCE')
);

// Featured projects for the resume (top 4 by date)
const resumeProjects = projects
  .filter(p => p.featured)
  .sort((a, b) => b.date - a.date)
  .slice(0, 4);
---

<BaseLayout title="Resume — Ethan Cornwill" description="Technical Lead & AI Developer. Systems architecture, prompt engineering, operational leadership.">
  <div class="resume-root min-h-screen bg-signal-black text-signal-white font-body">

    <!-- ── Header ─────────────────────────────────────────────────── -->
    <header class="bg-signal-charcoal/30 border-b-4 border-signal-orange px-6 md:px-12 py-10 md:py-14 print-header">
      <div class="max-w-[1400px] mx-auto">
        <a href="/" class="print:hidden font-mono text-[10px] text-signal-white/30 hover:text-signal-white transition-colors tracking-widest uppercase mb-6 inline-block">← Back</a>
        <div class="flex flex-col lg:flex-row justify-between items-start gap-8">
          <div>
            <p class="font-mono text-signal-orange text-xs uppercase tracking-[0.5em] mb-3 opacity-70">Resume</p>
            <h1 class="text-signal-white font-black uppercase italic tracking-tighter leading-none" style="font-size:clamp(2.5rem,6vw,5rem)">
              Ethan<br/><span class="text-signal-orange">Cornwill</span>
            </h1>
            <p class="mt-3 font-mono text-signal-white/40 text-xs tracking-[0.3em] uppercase not-italic font-normal">
              Technical Lead · AI Systems · Operations
            </p>
          </div>
          <div class="font-mono text-xs text-signal-white/50 space-y-1.5 leading-loose">
            <div><a href="mailto:ethan@finneh.xyz" class="hover:text-signal-orange transition-colors">ethan@finneh.xyz</a></div>
            <div><a href="https://finneh.xyz" class="hover:text-signal-orange transition-colors">finneh.xyz</a></div>
            <div><a href="https://linkedin.com/in/ethancornwill" class="hover:text-signal-orange transition-colors">linkedin.com/in/ethancornwill</a></div>
            <div class="text-signal-white/25">Melbourne, VIC, Australia</div>
          </div>
        </div>
      </div>
    </header>

    <div class="max-w-[1400px] mx-auto px-6 md:px-12 py-10 md:py-14 space-y-12 md:space-y-16">

      <!-- ── Summary ──────────────────────────────────────────────── -->
      <p class="text-signal-base md:text-signal-lg text-signal-white/75 leading-relaxed max-w-4xl border-t-2 border-signal-orange/40 pt-6">
        I architect <span class="text-signal-cyan font-bold">AI systems</span>, design prompt frameworks (SPARC), and build production tools that ship. A dual background in deep technology and high-pressure operations lets me bridge abstract engineering and real-world deployment.
      </p>

      <!-- ── Professional Experience — 2 columns ─────────────────── -->
      <section>
        <!-- Direction C: cyan surface section header -->
        <div class="surface-cyan px-6 py-4 mb-8 flex items-baseline justify-between">
          <h2 class="font-display font-black text-signal-black uppercase italic tracking-tighter leading-none" style="font-size:clamp(1.6rem,4vw,3rem)">Experience</h2>
          <span class="font-mono text-[9px] text-signal-black/50 uppercase tracking-widest print:hidden">2018 — Present</span>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 md:gap-16">

          <!-- Technology column -->
          <div>
            <h3 class="font-mono text-[10px] text-signal-cyan uppercase tracking-[0.5em] mb-6 flex items-center gap-3">
              <span class="w-4 h-px bg-signal-cyan"></span>Technology
            </h3>
            <div class="space-y-8">
              {techRoles.map((exp: any) => (
                <div class="resume-entry">
                  <div class="flex items-start gap-3 mb-3">
                    {exp.logoSrc && (
                      <div class="resume-logo shrink-0">
                        <img src={`/assets/images/${exp.logoSrc.split('/').pop()}`} alt={exp.company} class="w-full h-full object-contain" onerror="this.parentElement.style.display='none'" />
                      </div>
                    )}
                    <div class="flex-1 min-w-0">
                      <h4 class="font-black text-signal-white uppercase italic tracking-tight leading-tight text-signal-lg">{exp.company}</h4>
                      {exp.employer && <p class="font-mono text-[9px] text-signal-white/30 uppercase tracking-widest mt-0.5">{exp.employer}</p>}
                    </div>
                  </div>
                  {exp.roles.map((role: any) => (
                    <div class="pl-0 md:pl-11 mb-4 last:mb-0">
                      <div class="flex flex-col sm:flex-row sm:items-baseline justify-between gap-1 mb-1">
                        <span class="font-black text-signal-sm text-signal-cyan uppercase tracking-wide">{role.title}</span>
                        <span class="font-mono text-[9px] text-signal-white/25 tracking-widest shrink-0">{role.period}</span>
                      </div>
                      {role.isCurrent && (
                        <span class="inline-flex items-center gap-1.5 text-[9px] bg-signal-cyan text-signal-black px-2 py-0.5 font-black uppercase tracking-wide mb-2">
                          <span class="w-1 h-1 bg-signal-black rounded-full animate-pulse"></span>Current
                        </span>
                      )}
                      <p class="text-signal-white/55 text-signal-sm leading-relaxed">{role.description}</p>
                    </div>
                  ))}
                </div>
              ))}
            </div>
          </div>

          <!-- Operations column -->
          <div>
            <h3 class="font-mono text-[10px] text-signal-amber uppercase tracking-[0.5em] mb-6 flex items-center gap-3">
              <span class="w-4 h-px bg-signal-amber"></span>Operations
            </h3>
            <div class="space-y-8">
              {opsRoles.map((exp: any) => (
                <div class="resume-entry">
                  <div class="flex items-start gap-3 mb-3">
                    {exp.logoSrc && (
                      <div class="resume-logo shrink-0">
                        <img src={`/assets/images/${exp.logoSrc.split('/').pop()}`} alt={exp.company} class="w-full h-full object-contain" onerror="this.parentElement.style.display='none'" />
                      </div>
                    )}
                    <div class="flex-1 min-w-0">
                      <h4 class="font-black text-signal-white uppercase italic tracking-tight leading-tight text-signal-lg">{exp.company}</h4>
                      {exp.employer && <p class="font-mono text-[9px] text-signal-white/30 uppercase tracking-widest mt-0.5">{exp.employer}</p>}
                    </div>
                  </div>
                  {exp.roles.slice(0, 2).map((role: any) => (
                    <div class="pl-0 md:pl-11 mb-4 last:mb-0">
                      <div class="flex flex-col sm:flex-row sm:items-baseline justify-between gap-1 mb-1">
                        <span class="font-black text-signal-sm text-signal-amber uppercase tracking-wide">{role.title}</span>
                        <span class="font-mono text-[9px] text-signal-white/25 tracking-widest shrink-0">{role.period}</span>
                      </div>
                      <p class="text-signal-white/55 text-signal-sm leading-relaxed">{role.description}</p>
                    </div>
                  ))}
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- ── Selected Projects ─────────────────────────────────────── -->
      <section>
        <!-- Direction C: amber surface header -->
        <div class="surface-amber px-6 py-4 mb-8 flex items-baseline justify-between">
          <h2 class="font-display font-black text-signal-black uppercase italic tracking-tighter leading-none" style="font-size:clamp(1.6rem,4vw,3rem)">Projects</h2>
          <a href="/#projects" class="print:hidden font-mono text-[9px] text-signal-black/50 uppercase tracking-widest hover:text-signal-black transition-colors">All projects →</a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-px bg-signal-white/5">
          {resumeProjects.map((p) => (
            <div class="bg-signal-black p-6 md:p-8 hover:bg-signal-charcoal/40 transition-colors duration-300">
              <div class="flex justify-between items-start gap-4 mb-3">
                <h3 class="font-display font-black text-signal-white uppercase italic tracking-tight leading-tight text-signal-xl">{p.title}</h3>
                <span class="font-mono text-[9px] text-signal-white/25 tracking-widest shrink-0">{new Date(p.date).getFullYear()}</span>
              </div>
              <p class="text-signal-white/55 text-signal-sm leading-relaxed mb-4">{p.description}</p>
              <div class="flex flex-wrap gap-1.5">
                {(p.technologies || []).slice(0, 4).map(tech => (
                  <span class="font-mono text-[9px] text-signal-cyan/60 bg-signal-cyan/5 border border-signal-cyan/15 px-2 py-0.5">{tech}</span>
                ))}
              </div>
              {p.githubUrl && (
                <div class="mt-3">
                  <a href={p.githubUrl} class="font-mono text-[9px] text-signal-white/30 hover:text-signal-cyan transition-colors uppercase tracking-widest print:text-signal-black/50">
                    {p.githubUrl.replace('https://', '')}
                  </a>
                </div>
              )}
            </div>
          ))}
        </div>
      </section>

      <!-- ── Bottom row: Skills + Education ────────────────────────── -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 md:gap-16">

        <!-- Skills -->
        <section>
          <div class="surface-cyan px-6 py-4 mb-6 flex items-baseline justify-between">
            <h2 class="font-display font-black text-signal-black uppercase italic tracking-tighter leading-none" style="font-size:clamp(1.4rem,3vw,2.2rem)">Skills</h2>
          </div>
          <div class="space-y-5">
            {Object.entries(toolsByCategory).map(([category, tools]) => (
              <div>
                <span class="block font-mono text-[9px] text-signal-white/30 uppercase tracking-widest mb-2">{category}</span>
                <div class="flex flex-wrap gap-1.5">
                  {(tools as string[]).map(tool => (
                    <span class="text-[10px] font-mono text-signal-white/65 bg-signal-white/5 border border-signal-white/10 px-2.5 py-1">{tool}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- Education -->
        <section>
          <div class="surface-amber px-6 py-4 mb-6">
            <h2 class="font-display font-black text-signal-black uppercase italic tracking-tighter leading-none" style="font-size:clamp(1.4rem,3vw,2.2rem)">Education</h2>
          </div>
          <div class="space-y-6">
            {keyEdu.map(item => (
              <div class="border-t border-signal-white/8 pt-5">
                <div class="flex justify-between items-baseline gap-3 mb-1">
                  <h3 class="font-black text-signal-white uppercase italic tracking-tight not-italic text-signal-base">{item.institution}</h3>
                  <span class="font-mono text-[9px] text-signal-white/25 shrink-0">{item.year}</span>
                </div>
                <p class="font-mono text-[10px] text-signal-amber/60 uppercase tracking-wider">{item.program}</p>
                {item.gpa && <p class="font-mono text-[9px] text-signal-white/25 mt-1">{item.gpa}</p>}
              </div>
            ))}
          </div>
        </section>
      </div>

      <!-- Print button (screen only) -->
      <div class="print:hidden flex flex-col sm:flex-row gap-4 pt-4 border-t border-signal-white/8">
        <button onclick="window.print()" class="signal-btn">Print Resume</button>
        <a href="/" class="inline-flex items-center font-mono text-[10px] text-signal-white/30 tracking-widest uppercase hover:text-signal-white transition-colors">← Back to portfolio</a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .resume-section-heading {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 900;
    font-style: italic;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .resume-entry {
    border-top: 1px solid oklch(96% 0.005 258 / 0.08);
    padding-top: 1.25rem;
  }

  .resume-logo {
    width: 36px;
    height: 36px;
    background: oklch(18% 0.01 258);
    border: 1px solid oklch(96% 0.005 258 / 0.1);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4px;
    flex-shrink: 0;
  }

  /* ── Print ───────────────────────────────────────────────────────── */
  @media print {
    @page {
      size: A4 landscape;
      margin: 0.8cm 1cm;
    }

    /* Force all backgrounds + colors to render — no browser stripping */
    *,
    *::before,
    *::after {
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
      animation: none !important;
      transition: none !important;
    }

    /* Hide screen chrome */
    .print\:hidden,
    nav, footer,
    .scan-line,
    .signal-grid-bg {
      display: none !important;
    }

    /* Root: lock the dark canvas */
    .resume-root {
      background: oklch(9% 0.01 258) !important;
      color: oklch(96% 0.005 258) !important;
      font-size: 8.5pt;
      line-height: 1.4;
      min-height: unset;
    }

    /* Tighten the max-width container */
    .max-w-\[1400px\] {
      max-width: 100% !important;
      padding-left: 0 !important;
      padding-right: 0 !important;
    }

    /* Header */
    header {
      background: oklch(13% 0.01 258 / 0.3) !important;
      border-bottom: 4pt solid oklch(68% 0.21 46) !important;
      padding: 10pt 12pt !important;
      margin-bottom: 0 !important;
    }

    header h1 {
      font-size: 26pt !important;
      line-height: 1 !important;
      color: oklch(96% 0.005 258) !important;
    }

    header h1 span {
      color: oklch(68% 0.21 46) !important;
    }

    header p,
    header div,
    header a {
      color: oklch(96% 0.005 258 / 0.5) !important;
    }

    /* Summary text border */
    .border-t-2 {
      border-top-color: oklch(68% 0.21 46 / 0.4) !important;
    }

    /* Section header bands: preserve the coloured blocks */
    .surface-cyan {
      background: oklch(72% 0.18 195) !important;
      padding: 6pt 12pt !important;
      margin-bottom: 8pt !important;
    }

    .surface-amber {
      background: oklch(78% 0.16 72) !important;
      padding: 6pt 12pt !important;
      margin-bottom: 8pt !important;
    }

    .surface-cyan h2,
    .surface-amber h2 {
      color: oklch(9% 0.01 258) !important;
      font-size: 14pt !important;
    }

    /* Accent colors */
    .text-signal-cyan { color: oklch(72% 0.18 195) !important; }
    .text-signal-amber { color: oklch(78% 0.16 72) !important; }
    .text-signal-orange { color: oklch(68% 0.21 46) !important; }

    /* Body text shades */
    .text-signal-white\/75,
    .text-signal-white\/55 {
      color: oklch(96% 0.005 258 / 0.7) !important;
    }
    .text-signal-white\/30,
    .text-signal-white\/25 {
      color: oklch(96% 0.005 258 / 0.35) !important;
    }
    .text-signal-white {
      color: oklch(96% 0.005 258) !important;
    }

    /* Headings */
    h3, h4 {
      color: oklch(96% 0.005 258) !important;
      font-size: 9pt !important;
    }

    p, li, span { font-size: 8pt !important; }

    /* 2-col experience + bottom grids */
    .grid.grid-cols-1.lg\:grid-cols-2 {
      display: grid !important;
      grid-template-columns: 1fr 1fr !important;
      gap: 12pt !important;
    }

    /* Project grid: 2 col */
    .grid.grid-cols-1.sm\:grid-cols-2 {
      display: grid !important;
      grid-template-columns: 1fr 1fr !important;
      gap: 1pt !important;
      background: oklch(96% 0.005 258 / 0.05) !important;
    }

    /* Project cards */
    .bg-signal-black {
      background: oklch(9% 0.01 258) !important;
    }

    /* Resume entry dividers */
    .resume-entry {
      border-top: 0.5pt solid oklch(96% 0.005 258 / 0.1) !important;
      padding-top: 6pt !important;
      break-inside: avoid;
      page-break-inside: avoid;
    }

    /* Logo boxes */
    .resume-logo {
      background: oklch(18% 0.01 258) !important;
      border: 0.5pt solid oklch(96% 0.005 258 / 0.12) !important;
    }

    /* Skill / tech tags */
    .border-signal-cyan\/15 { border-color: oklch(72% 0.18 195 / 0.2) !important; }
    .bg-signal-cyan\/5 { background: oklch(72% 0.18 195 / 0.06) !important; }
    .text-signal-cyan\/60 { color: oklch(72% 0.18 195 / 0.7) !important; }
    .border-signal-white\/10 { border-color: oklch(96% 0.005 258 / 0.12) !important; }
    .bg-signal-white\/5 { background: oklch(96% 0.005 258 / 0.05) !important; }
    .border-signal-white\/8 { border-color: oklch(96% 0.005 258 / 0.1) !important; }
    .text-signal-amber\/60 { color: oklch(78% 0.16 72 / 0.75) !important; }

    /* Spacing compression for print */
    .py-10, .md\:py-14 { padding-top: 10pt !important; padding-bottom: 10pt !important; }
    .space-y-12 > * + *, .md\:space-y-16 > * + * { margin-top: 10pt !important; }
    .space-y-8 > * + * { margin-top: 8pt !important; }
    .space-y-5 > * + * { margin-top: 5pt !important; }
    .space-y-6 > * + * { margin-top: 6pt !important; }
    .gap-10, .md\:gap-16 { gap: 10pt !important; }
    .mb-8 { margin-bottom: 6pt !important; }
    .mb-6 { margin-bottom: 5pt !important; }
    .mb-3 { margin-bottom: 2pt !important; }
    .p-6, .md\:p-8 { padding: 6pt !important; }
    .px-6, .md\:px-12 { padding-left: 0 !important; padding-right: 0 !important; }
    .pt-6 { padding-top: 6pt !important; }

    /* Page break hints */
    h2 { break-after: avoid; page-break-after: avoid; }
    h3, h4 { break-after: avoid; page-break-after: avoid; }
    section { break-inside: avoid; page-break-inside: avoid; }

    /* Links */
    a[href] {
      color: oklch(96% 0.005 258 / 0.5) !important;
      text-decoration: none !important;
    }

    .font-mono { font-size: 7.5pt !important; }
  }
</style>
