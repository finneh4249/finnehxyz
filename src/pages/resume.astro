---
import BaseLayout from '../layouts/BaseLayout.astro';
import experienceData from '../data/experience.json';
import skillsData from '../data/skills.json';
import educationItems from '../data/education.json';

// Only keep most relevant roles (recent / current / significant)
const techRoles = (experienceData as any[])
  .filter(e => e.category === 'technology')
  .map(e => ({
    company: e.company,
    employer: e.employer,
    roles: e.roles.filter((r: any) => r.isCurrent || r.title.includes('Lead') || r.title.includes('Founder')).slice(0, 1),
  }))
  .filter(e => e.roles.length > 0);

const opsRoles = (experienceData as any[])
  .filter(e => e.category === 'operations')
  .map(e => ({
    company: e.company,
    employer: e.employer,
    roles: e.roles.slice(0, 2), // Latest 2 roles per company
  }));

// Top skills by proficiency
const topTools = skillsData.tools
  .sort((a, b) => b.proficiency - a.proficiency)
  .slice(0, 14);

// Group tools by category
const toolsByCategory = topTools.reduce((acc: Record<string, string[]>, tool) => {
  if (!acc[tool.category]) acc[tool.category] = [];
  acc[tool.category].push(tool.name);
  return acc;
}, {} as Record<string, string[]>);

// Key education only
const keyEdu = educationItems.filter(e =>
  e.program.includes('Diploma') || e.program.includes('VCE')
);
const excludedCompetencyTitles = new Set(['Technical Leadership']);
const coreCompetencies = skillsData.skills
  .filter(skill => skill.category !== 'Leadership' && !excludedCompetencyTitles.has(skill.title))
  .slice(0, 6);

const technicalProjectHighlights = [
  {
    title: 'Nexus (FinTech)',
    period: 'Production Prototype',
    summary: 'Implemented PostgreSQL relational schemas, SQL query workflows, and encrypted finance record handling for shared budgeting operations.',
    stack: ['PostgreSQL', 'SQL', 'Node.js', 'React'],
  },
  {
    title: 'HomeLab / Server Infrastructure',
    period: 'Ongoing',
    summary: 'Administered Docker-based services, host configuration baselines, and operational monitoring to maintain service availability and recoverability.',
    stack: ['Docker', 'Linux', 'Systems Configuration (COTS)', 'Workflow Automation'],
  },
];
---

<BaseLayout title="Resume — Ethan Cornwill" description="Professional resume of Ethan Cornwill, Systems Administrator & Technical Operations Specialist">
  <div class="resume-page bg-cyber-bg min-h-screen py-8 px-4 print:bg-white print:py-0 print:px-0">
    <div class="max-w-[210mm] mx-auto">

      <!-- Resume Grid -->
      <div class="resume-grid">

        <!-- ═══ HEADER ═══ -->
        <div class="resume-cell col-span-full border-b-2 border-cyber-cyan print:border-black pb-4 mb-2">
          <div class="flex flex-col md:flex-row justify-between items-start gap-2">
            <div>
              <h1 class="text-3xl md:text-4xl font-black uppercase tracking-tight text-white print:text-black">
                Ethan Cornwill
              </h1>
              <p class="text-sm font-mono text-cyber-cyan print:text-gray-700 mt-1">
                Systems Administrator &amp; Technical Operations Specialist
              </p>
            </div>
            <div class="font-mono text-[10px] text-cyber-text-muted print:text-gray-600 text-right space-y-0.5">
              <div>mail@finneh.xyz</div>
              <div>finneh.xyz</div>
              <div>Melbourne, Australia</div>
              <div>github.com/finneh4249</div>
            </div>
          </div>

          <!-- Summary -->
          <p class="text-xs text-cyber-text print:text-gray-700 mt-3 leading-relaxed max-w-3xl">
            Technical operator with 10+ years in high-pressure environments maintaining Operations Technology Platform (OTP) uptime, data integrity, and production stability. Experienced across systems administration, incident response, and procedural governance in Australian operations contexts, with applied industry knowledge of aviation workflows and radio telephony protocol standards.
          </p>
        </div>

        <!-- ═══ LEFT COLUMN ═══ -->

        <!-- Tech Experience -->
        <div class="resume-cell resume-left">
          <h2 class="resume-section-title">Technology Experience</h2>
          {technicalProjectHighlights.map(project => (
            <div class="mb-3">
              <div class="flex items-baseline justify-between gap-2">
                <h3 class="text-xs font-bold text-white print:text-black uppercase">{project.title}</h3>
                <span class="text-[9px] font-mono text-cyber-text-muted print:text-gray-500 whitespace-nowrap">{project.period}</span>
              </div>
              <p class="text-[9px] text-cyber-text print:text-gray-600 mt-1 leading-relaxed">{project.summary}</p>
              <div class="flex flex-wrap gap-1 mt-1">
                {project.stack.map(item => (
                  <span class="text-[9px] font-mono text-cyber-text print:text-gray-600 border border-cyber-border print:border-gray-300 px-1.5 py-0.5">{item}</span>
                ))}
              </div>
            </div>
          ))}
          {techRoles.map(exp => (
            <div class="mb-3">
              <div class="flex items-baseline justify-between gap-2">
                <h3 class="text-xs font-bold text-white print:text-black uppercase">{exp.company.split('—')[0].trim()}</h3>
              </div>
              {exp.employer && <p class="text-[9px] font-mono text-cyber-text-muted print:text-gray-500">{exp.employer}</p>}
              {exp.roles.map((role: any) => (
                <div class="mt-1">
                  <div class="flex items-baseline justify-between gap-2">
                    <span class="text-[10px] font-bold text-cyber-cyan print:text-gray-800">{role.title}</span>
                    <span class="text-[9px] font-mono text-cyber-text-muted print:text-gray-500 whitespace-nowrap">{role.period}</span>
                  </div>
                  {role.description && (
                    <div class="text-[9px] text-cyber-text print:text-gray-600 mt-1 leading-relaxed space-y-0.5">
                      {role.description.split('\n').filter((l: string) => l.startsWith('- ')).slice(0, 3).map((line: string) => (
                        <div class="flex items-start gap-1">
                          <span class="text-cyber-cyan print:text-black mt-px">•</span>
                          <span>{line.substring(2)}</span>
                        </div>
                      ))}
                      {!role.description.includes('\n') && <p>{role.description.slice(0, 200)}{role.description.length > 200 ? '...' : ''}</p>}
                    </div>
                  )}
                </div>
              ))}
            </div>
          ))}
        </div>

        <!-- Ops Experience -->
        <div class="resume-cell resume-right">
          <h2 class="resume-section-title">Operational Reliability Experience</h2>
          {opsRoles.map(exp => (
            <div class="mb-3">
              <h3 class="text-xs font-bold text-white print:text-black uppercase">{exp.company}</h3>
              {exp.employer && <p class="text-[9px] font-mono text-cyber-text-muted print:text-gray-500">{exp.employer}</p>}
              {exp.roles.map((role: any) => (
                <div class="mt-1">
                  <div class="flex items-baseline justify-between gap-2">
                    <span class="text-[10px] font-bold text-cyber-magenta print:text-gray-800">{role.title}</span>
                    <span class="text-[9px] font-mono text-cyber-text-muted print:text-gray-500 whitespace-nowrap">{role.period}</span>
                  </div>
                  {role.description && (
                    <div class="text-[9px] text-cyber-text print:text-gray-600 mt-1 leading-relaxed space-y-0.5">
                      {role.description.split('\n').filter((l: string) => l.startsWith('- ')).slice(0, 2).map((line: string) => (
                        <div class="flex items-start gap-1">
                          <span class="text-cyber-magenta print:text-black mt-px">•</span>
                          <span>{line.substring(2)}</span>
                        </div>
                      ))}
                      {!role.description.includes('\n') && <p>{role.description.slice(0, 150)}{role.description.length > 150 ? '...' : ''}</p>}
                    </div>
                  )}
                </div>
              ))}
            </div>
          ))}
        </div>

        <!-- Skills -->
        <div class="resume-cell resume-left">
          <h2 class="resume-section-title">Skills &amp; Tools</h2>
          <div class="space-y-2">
            {Object.entries(toolsByCategory).map(([category, tools]) => (
              <div>
                <span class="text-[9px] font-mono font-bold text-cyber-cyan print:text-gray-800 uppercase tracking-wider">{category}</span>
                <div class="flex flex-wrap gap-1 mt-0.5">
                  {(tools as string[]).map(tool => (
                    <span class="text-[9px] font-mono text-cyber-text print:text-gray-600 border border-cyber-border print:border-gray-300 px-1.5 py-0.5">{tool}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>

          <!-- Core competencies -->
          <div class="mt-3 pt-2 border-t border-cyber-border print:border-gray-300">
            <div class="flex flex-wrap gap-1">
              {coreCompetencies.map(skill => (
                <span class="text-[9px] font-mono text-cyber-text-muted print:text-gray-500 border border-cyber-border/50 print:border-gray-200 px-1.5 py-0.5">{skill.title}</span>
              ))}
            </div>
          </div>
          <div class="mt-3 pt-2 border-t border-cyber-border print:border-gray-300">
            <span class="text-[9px] font-mono font-bold text-cyber-cyan print:text-gray-800 uppercase tracking-wider">Technical Capabilities</span>
            <div class="flex flex-wrap gap-1 mt-1">
              {[
                'Relational Databases (SQL)',
                'Systems Configuration (COTS)',
                'Workflow Automation',
                'Stakeholder Technical Advisory',
                'Security Groups & Permissions (IAM)',
              ].map(capability => (
                <span class="text-[9px] font-mono text-cyber-text print:text-gray-600 border border-cyber-border print:border-gray-300 px-1.5 py-0.5">{capability}</span>
              ))}
            </div>
          </div>
        </div>

        <!-- Education -->
        <div class="resume-cell resume-right">
          <h2 class="resume-section-title">Education &amp; Certs</h2>
          <div class="space-y-2">
            {keyEdu.map(item => (
              <div>
                <div class="flex items-baseline justify-between gap-2">
                  <h3 class="text-[10px] font-bold text-white print:text-black">{item.institution}</h3>
                  <span class="text-[9px] font-mono text-cyber-text-muted print:text-gray-500">{item.year}</span>
                </div>
                <p class="text-[9px] font-mono text-cyber-green print:text-gray-600">{item.program}</p>
                {'gpa' in item && item.gpa && <p class="text-[9px] font-mono text-cyber-text-muted print:text-gray-500">GPA: {item.gpa}</p>}
              </div>
            ))}
          </div>
        </div>

        <div class="resume-cell resume-right">
          <h2 class="resume-section-title">Industry Knowledge</h2>
          <div class="space-y-1 text-[9px] text-cyber-text print:text-gray-600 leading-relaxed">
            <div class="flex items-start gap-1">
              <span class="text-cyber-magenta print:text-black mt-px">•</span>
              <span>Australian aviation operating environment, including procedural discipline and safety-critical communication expectations.</span>
            </div>
            <div class="flex items-start gap-1">
              <span class="text-cyber-magenta print:text-black mt-px">•</span>
              <span>Radio telephony protocols and phraseology conventions used in controlled, high-reliability operational settings.</span>
            </div>
            <div class="flex items-start gap-1">
              <span class="text-cyber-magenta print:text-black mt-px">•</span>
              <span>Operational governance mindset: checklist execution, procedural compliance, and evidence-based escalation.</span>
            </div>
          </div>
        </div>

      </div>

      <!-- Print-only footer -->
      <div class="hidden print:block text-center text-[8px] text-gray-400 mt-4 pt-2 border-t border-gray-200">
        Generated from finneh.xyz — {new Date().toISOString().slice(0, 10)}
      </div>

      <!-- Screen-only actions -->
      <div class="flex justify-center gap-4 mt-8 print:hidden">
        <button onclick="window.print()" class="cyber-btn-primary px-6 py-3 text-xs font-mono">
          PRINT / SAVE PDF
        </button>
        <a href="/" class="cyber-btn px-6 py-3 text-xs font-mono">
          ← BACK
        </a>
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .resume-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 8px;
  }

  @media (min-width: 640px) {
    .resume-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .resume-cell {
    padding: 8px 0;
  }

  .resume-left { grid-column: 1; }
  .resume-right { grid-column: 1; }

  @media (min-width: 640px) {
    .resume-left { grid-column: 1; }
    .resume-right { grid-column: 2; }
  }

  .col-span-full { grid-column: 1 / -1; }

  .resume-section-title {
    font-size: 11px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-bottom: 1px solid rgba(0, 255, 245, 0.3);
    padding-bottom: 4px;
    margin-bottom: 8px;
    color: #fff;
    font-family: monospace;
  }

  @media print {
    .resume-page {
      background: white !important;
      padding: 0 !important;
      min-height: auto !important;
    }

    .resume-grid {
      grid-template-columns: 1fr 1fr !important;
      gap: 6px !important;
    }

    .resume-cell {
      padding: 4px 0 !important;
    }

    .resume-section-title {
      color: #000 !important;
      border-bottom-color: #000 !important;
      font-size: 10px !important;
    }

    * {
      color-adjust: exact;
      -webkit-print-color-adjust: exact;
    }

    @page {
      size: A4;
      margin: 1.2cm 1.5cm;
    }
  }
</style>
