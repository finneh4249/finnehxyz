---
import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props;

function formatDate(d: string | Date) {
  const date = d instanceof Date ? d : new Date(d);
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}

function isoDate(d: string | Date) {
  const date = d instanceof Date ? d : new Date(d);
  return isNaN(date.getTime()) ? String(d) : date.toISOString().slice(0, 10);
}

function estimateReadingTime(content: string) {
  const wordCount = content.trim().split(/\s+/).length;
  return Math.ceil(wordCount / 200);
}
---

<BaseLayout 
  title={frontmatter.title} 
  description={frontmatter.description}
>
  <article class="min-h-screen bg-cyber-bg py-16 px-4">
    <div class="max-w-3xl mx-auto">
      
      <!-- Back to Blog -->
      <a 
        href="/blog"
        class="inline-flex items-center gap-2 mb-8 font-mono text-sm text-cyber-cyan hover:underline transition-all group"
      >
        <span class="group-hover:-translate-x-1 transition-transform">←</span>
        <span>cd /blog</span>
      </a>

      <!-- Article Header -->
      <header class="mb-10 pb-8 border-b border-cyber-border">
        <!-- Tags -->
        {frontmatter.tags && (
          <div class="flex flex-wrap gap-1.5 mb-4">
            {frontmatter.tags.map((tag: string) => (
              <span class="text-[9px] font-mono uppercase tracking-wider text-cyber-cyan border border-cyber-cyan/30 px-2 py-0.5">
                {tag}
              </span>
            ))}
          </div>
        )}

        <!-- Title -->
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-black uppercase leading-[1.1] tracking-tight text-white mb-4">
          {frontmatter.title}
        </h1>

        <!-- Meta -->
        <div class="flex items-center gap-4 font-mono text-xs text-cyber-text-muted">
          <time datetime={frontmatter.pubDate}>
            {isoDate(frontmatter.pubDate)}
          </time>
          <span class="text-cyber-border">|</span>
          <span>~{estimateReadingTime(frontmatter.description || '')} min read</span>
          <span class="text-cyber-border">|</span>
          <span>by Ethan Cornwill</span>
        </div>
      </header>

      <!-- Article Content -->
      <div class="blog-content">
        <slot />
      </div>

      <!-- Article Footer -->
      <footer class="mt-16 pt-8 border-t border-cyber-border">
        <div class="bg-cyber-surface border border-cyber-border p-6 border-l-2 border-l-cyber-magenta">
          <h3 class="text-sm font-bold uppercase text-white mb-2 font-mono">// about the author</h3>
          <p class="text-sm text-cyber-text leading-relaxed mb-3">
            I'm Ethan Cornwill. 13+ years building software, 10 years managing QSR operations. 
            Now I design AI systems, write prompt architecture, and build tools that ship.
          </p>
          <div class="flex items-center gap-4 font-mono text-xs">
            <a href="https://github.com/finneh4249" class="text-cyber-cyan hover:underline" target="_blank" rel="noopener noreferrer">
              github
            </a>
            <a href="https://www.linkedin.com/in/ethan-cornwill/" class="text-cyber-blue hover:underline" target="_blank" rel="noopener noreferrer">
              linkedin
            </a>
            <a href="https://x.com/FinnehReform" class="text-cyber-purple hover:underline" target="_blank" rel="noopener noreferrer">
              twitter
            </a>
          </div>
        </div>
      </footer>

    </div>
  </article>
</BaseLayout>

<style is:global>
  /* Blog Content — Cyberpunk Prose */
  .blog-content {
    line-height: 1.8;
    color: #b8c0cc;
  }

  .blog-content h2 {
    font-size: 1.75rem;
    font-weight: 900;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.2;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    border-left: 3px solid #00fff5;
    padding-left: 0.75rem;
  }

  .blog-content h3 {
    font-size: 1.35rem;
    font-weight: 800;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: #00fff5;
    text-transform: uppercase;
    letter-spacing: -0.01em;
  }

  .blog-content h4 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    color: #ff00ff;
    font-family: 'JetBrains Mono', monospace;
  }

  .blog-content p {
    margin-bottom: 1.25rem;
    font-size: 0.95rem;
  }

  .blog-content a {
    color: #00fff5;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s;
  }

  .blog-content a:hover {
    color: #ff00ff;
  }

  .blog-content ul, .blog-content ol {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }

  .blog-content li {
    margin-bottom: 0.5rem;
    font-size: 0.95rem;
  }

  .blog-content li::marker {
    color: #00fff5;
  }

  .blog-content strong {
    font-weight: 800;
    color: #ffe600;
  }

  .blog-content em {
    font-style: italic;
    color: #00b4d8;
  }

  .blog-content code {
    background: #1a1a2e;
    color: #00fff5;
    padding: 0.15rem 0.4rem;
    border: 1px solid #2a2a3a;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85em;
  }

  .blog-content pre {
    background: #0a0a14 !important;
    border: 1px solid #2a2a3a;
    padding: 1.25rem;
    margin: 1.5rem 0;
    overflow-x: auto;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    line-height: 1.6;
  }

  .blog-content pre code {
    background: none;
    border: none;
    padding: 0;
    color: inherit;
  }

  .blog-content blockquote {
    border-left: 3px solid #ff00ff;
    padding: 0.75rem 1rem;
    margin: 1.5rem 0;
    background: rgba(255, 0, 255, 0.05);
    font-style: italic;
    color: #d4d4e0;
  }

  .blog-content hr {
    border: none;
    border-top: 1px solid #2a2a3a;
    margin: 2.5rem 0;
  }

  .blog-content img {
    border: 1px solid #2a2a3a;
    margin: 1.5rem 0;
  }

  /* Tables */
  .blog-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.85rem;
    font-family: 'JetBrains Mono', monospace;
  }

  .blog-content th {
    background: #1a1a2e;
    color: #00fff5;
    padding: 0.6rem 0.75rem;
    text-align: left;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    border-bottom: 1px solid #2a2a3a;
  }

  .blog-content td {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid #1a1a2e;
    color: #b8c0cc;
  }

  .blog-content tr:hover td {
    background: rgba(0, 255, 245, 0.03);
  }
</style>
